<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../head.ejs') %>
</head>
<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 transition-colors duration-300 min-h-screen font-sans">
  <div class="flex flex-col min-h-screen">
    <main class="p-4 md:p-10 flex-grow">
      <div class="max-w-7xl mx-auto">
        <div class="mb-6">
          <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
            <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
            Back
          </button>
        </div>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
          <div>
            <h1 class="text-4xl font-black tracking-wide text-zinc-900 dark:text-zinc-100 uppercase">
              Order <span class="text-kaizen-orange">Management</span>
            </h1>
            <p class="text-zinc-500 dark:text-zinc-400 font-medium italic mt-1">"Track and manage customer orders."</p>
          </div>
        </div>

        <div class="bg-white dark:bg-kaizen-dark border border-kaizen-tan dark:border-zinc-800 rounded-2xl shadow-sm overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-[#f5ece0] dark:bg-zinc-900 border-b border-kaizen-tan dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-xs uppercase font-bold tracking-widest">
                  <th class="px-6 py-4">Order ID & Date</th>
                  <th class="px-6 py-4">Customer / Table</th>
                  <th class="px-6 py-4">Amount</th>
                  <th class="px-6 py-4">Status</th>
                  <th class="px-6 py-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-kaizen-tan/50 dark:divide-zinc-800">
                <% if(typeof orders !== 'undefined' && orders.length > 0) { %>
                  <% orders.forEach(order => { %>
                  <tr class="hover:bg-[#faf8f5] dark:hover:bg-zinc-800/50 transition-colors group">
                    <td class="px-6 py-5">
                      <div class="font-bold text-zinc-900 dark:text-zinc-100">#<%= order._id.toString().substring(0,6).toUpperCase() %></div>
                      <div class="text-xs text-zinc-500 mt-1"><%= new Date(order.createdAt).toLocaleString() %></div>
                    </td>
                    <td class="px-6 py-5">
                      <div class="font-bold text-zinc-800 dark:text-zinc-200"><%= order.customerName || 'Walk-in' %></div>
                    </td>
                    <td class="px-6 py-5">
                      <div class="text-base font-black text-kaizen-red dark:text-kaizen-orange">฿<%= order.totalAmount.toLocaleString() %></div>
                    </td>
                    <td class="px-6 py-5">
                  <select onchange="updateOrderStatus('<%= order._id %>', this)" 
        class="appearance-none cursor-pointer px-4 py-1.5 rounded-lg text-[11px] font-black uppercase tracking-wider border-none outline-none transition-all text-white
        <%= (order.status && order.status.toLowerCase() === 'completed') ? 'bg-emerald-500' : 
            (order.status && order.status.toLowerCase() === 'preparing') ? 'bg-sky-500' : 
            (order.status && order.status.toLowerCase() === 'cancelled') ? 'bg-red-500' : 'bg-zinc-600' %>">
    
    <option value="Preparing" class="bg-white text-zinc-900" <%= (order.status && order.status.toLowerCase() === 'preparing') ? 'selected' : '' %>>Preparing</option>
    <option value="Completed" class="bg-white text-zinc-900" <%= (order.status && order.status.toLowerCase() === 'completed') ? 'selected' : '' %>>Completed</option>
    <option value="Cancelled" class="bg-white text-zinc-900" <%= (order.status && order.status.toLowerCase() === 'cancelled') ? 'selected' : '' %>>Cancelled</option>
</select>
                    </td>
                    <td class="px-6 py-5 text-right">
                      <div class="inline-flex items-center space-x-3">
                        <a href="/orders/view/<%= order._id %>" class="text-zinc-400 hover:text-blue-500 transition-colors">
                          <i data-lucide="eye" class="w-5 h-5"></i>
                        </a>
                        <form id="delete-form-<%= order._id %>" action="/orders/delete/<%= order._id %>" method="POST" class="inline">
                          <button type="button" onclick="confirmDelete('<%= order._id %>', 'Order #<%= order._id.toString().substring(0,6).toUpperCase() %>')" class="text-zinc-400 hover:text-kaizen-red transition-colors">
                            <i data-lucide="trash-2" class="w-5 h-5"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script>
    lucide.createIcons();

    async function updateOrderStatus(orderId, selectElement) {
      const newStatus = selectElement.value;
      selectElement.classList.remove('bg-emerald-500', 'bg-sky-500', 'bg-red-500', 'bg-zinc-600');
      
      if (newStatus === 'Completed') selectElement.classList.add('bg-emerald-500');
      else if (newStatus === 'Preparing') selectElement.classList.add('bg-sky-500');
      else if (newStatus === 'Cancelled') selectElement.classList.add('bg-red-500');
      else selectElement.classList.add('bg-zinc-600');

      try {
        await fetch(`/orders/update-status/${orderId}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ status: newStatus })
        });
      } catch (error) {
        console.error(error);
      }
    }

    function confirmDelete(id, name) {
      const isDark = document.documentElement.classList.contains('dark');
      Swal.fire({
        title: 'Delete Order?',
        html: `Are you sure you want to delete <b>${name}</b>?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#E60000',
        cancelButtonColor: isDark ? '#3f3f46' : '#a1a1aa',
        background: isDark ? '#18181b' : '#ffffff',
        color: isDark ? '#f4f4f5' : '#18181b',
        confirmButtonText: 'Yes, delete it!'
      }).then((result) => {
        if (result.isConfirmed) document.getElementById(`delete-form-${id}`).submit();
      });
    }
  </script>
</body>
</html>