<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../head.ejs') %>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
      tailwind.config = {
          darkMode: 'class',
          theme: {
              extend: {
                  colors: {
                      kaizen: {
                          bg: '#fdfbf7',
                          red: '#E60000',
                          orange: '#ea580c',
                          tan: '#e8dccb',
                          dark: '#18181b',
                          darker: '#09090b'
                      }
                  }
              }
          }
      }
  </script>
</head>
<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 transition-colors duration-300 min-h-screen font-sans">
    
    <div class="flex flex-col min-h-screen relative">
        <main class="p-4 md:p-10 flex-grow">
            <div class="max-w-7xl mx-auto">
                 <div class="mb-6">
            <a href="/dashboard" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                Back
            </a>
        </div>
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                    <div>
                        <h1 class="text-4xl font-black tracking-wide text-zinc-900 dark:text-zinc-100 uppercase">
                            Kaizen <span class="text-kaizen-orange">Staff</span>
                        </h1>
                        <p class="text-zinc-500 dark:text-zinc-400 font-medium italic mt-1">"The art of continuous improvement, starting with our crew."</p>
                    </div>
                    
                    <div class="flex items-center gap-4">
                        <button onclick="toggleDarkMode()" class="p-3 rounded-full bg-white dark:bg-kaizen-dark shadow-sm border border-kaizen-tan dark:border-zinc-800 hover:scale-105 transition flex items-center justify-center text-kaizen-orange">
                            <i data-lucide="moon" id="icon-moon" class="w-5 h-5"></i>
                            <i data-lucide="sun" id="icon-sun" class="w-5 h-5 hidden"></i>
                        </button>
                        <a href="/employee/add" class="flex items-center gap-2 bg-[#1db954] hover:bg-green-600 text-white font-bold py-3 px-8 rounded-full shadow-md transition-all active:scale-95 tracking-wide uppercase text-sm">
                            <i data-lucide="plus" class="w-4 h-4"></i> Add Employee
                        </a>
                    </div>
                </div>

                <div class="bg-white dark:bg-kaizen-dark border border-kaizen-tan dark:border-zinc-800 rounded-2xl shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-[#f5ece0] dark:bg-zinc-900 border-b border-kaizen-tan dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-xs uppercase font-bold tracking-widest">
                                    <th class="px-6 py-4 text-center w-24">Photo</th>
                                    <th class="px-6 py-4">Crew Details</th>
                                    <th class="px-6 py-4">Role & Salary</th>
                                    <th class="px-6 py-4">Status</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-kaizen-tan/50 dark:divide-zinc-800">
                                <% employees.forEach(emp => { %>
                                <tr class="hover:bg-[#faf8f5] dark:hover:bg-zinc-800/50 transition-colors group">
                                    <td class="px-6 py-5">
                                        <div class="relative w-12 h-12 mx-auto">
                                            <img src="/images/employeeProfile/<%= emp.image %>" class="w-full h-full rounded-full object-cover border border-kaizen-tan dark:border-zinc-700">
                                            <% if(emp.isActive) { %>
                                                <span class="absolute -top-1 -right-1 w-3.5 h-3.5 bg-emerald-500 border-2 border-white dark:border-kaizen-dark rounded-full"></span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <div class="font-bold text-zinc-900 dark:text-zinc-100 text-base group-hover:text-kaizen-orange transition-colors uppercase tracking-wide"><%= emp.name %></div>
                                        <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5"><%= emp.email %></div>
                                        <div class="text-xs text-kaizen-orange font-medium mt-1"><%= emp.phone %></div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider
                                            <%= emp.role === 'admin' ? 'bg-orange-100 text-kaizen-orange dark:bg-orange-900/30 dark:text-orange-400' : 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400' %>">
                                            <%= emp.role %>
                                        </span>
                                        <div class="text-sm font-bold text-zinc-700 dark:text-zinc-300 mt-2">฿<%= emp.salary.toLocaleString() %></div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <% if(emp.isActive) { %>
                                            <span class="inline-flex items-center text-emerald-600 dark:text-emerald-400 text-sm font-medium">
                                                <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full mr-2"></span> Active
                                            </span>
                                        <% } else { %>
                                            <span class="inline-flex items-center text-zinc-400 text-sm font-medium">
                                                <span class="w-1.5 h-1.5 bg-zinc-300 dark:bg-zinc-600 rounded-full mr-2"></span> Inactive
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="px-6 py-5 text-right">
                                        <div class="inline-flex items-center space-x-3">
                                            <a href="/employee/edit/<%= emp._id %>" class="text-zinc-400 hover:text-kaizen-orange transition-colors">
                                                <i data-lucide="pencil" class="w-5 h-5"></i>
                                            </a>
                                            
                                            <form id="delete-form-<%= emp._id %>" action="/employee/delete/<%= emp._id %>" method="POST" class="inline">
                                                <button type="button" onclick="openDeleteModal('<%= emp._id %>')" class="text-zinc-400 hover:text-kaizen-red transition-colors">
                                                    <i data-lucide="trash-2" class="w-5 h-5"></i>
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    
                    <% if(employees.length === 0) { %>
                    <div class="py-20 text-center flex flex-col items-center justify-center">
                        <i data-lucide="users" class="w-12 h-12 text-kaizen-tan dark:text-zinc-700 mb-4"></i>
                        <p class="text-zinc-500 dark:text-zinc-500 text-base font-medium">No employees found.</p>
                    </div>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <div id="deleteModal" class="fixed inset-0 z-50 hidden items-center justify-center">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm transition-opacity" onclick="closeDeleteModal()"></div>
        
        <div class="relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl shadow-xl w-full max-w-sm p-6 transform scale-95 opacity-0 transition-all duration-200" id="deleteModalContent">
            <div class="flex flex-col items-center text-center">
                <div class="w-12 h-12 rounded-full bg-red-100 dark:bg-red-900/30 flex items-center justify-center mb-4">
                    <i data-lucide="alert-triangle" class="w-6 h-6 text-kaizen-red"></i>
                </div>
                <h3 class="text-xl font-bold text-zinc-900 dark:text-white mb-2 uppercase tracking-wide">Remove Employee?</h3>
                <p class="text-zinc-500 dark:text-zinc-400 text-sm mb-6">
                    Are you sure you want to remove this employee from the system? This action cannot be undone.
                </p>
                
                <div class="flex w-full gap-3">
                    <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 rounded-xl font-bold text-zinc-600 dark:text-zinc-300 bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 transition-colors">
                        Cancel
                    </button>
                    <button type="button" onclick="confirmDelete()" class="flex-1 px-4 py-2.5 rounded-xl font-bold text-white bg-kaizen-red hover:bg-red-700 transition-colors shadow-md shadow-red-500/20">
                        Remove
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();

        // Dark Mode Logic
        function toggleDarkMode() {
            const html = document.documentElement;
            const iconMoon = document.getElementById('icon-moon');
            const iconSun = document.getElementById('icon-sun');
            
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
                iconMoon.classList.remove('hidden');
                iconSun.classList.add('hidden');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
                iconMoon.classList.add('hidden');
                iconSun.classList.remove('hidden');
            }
        }

        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
            document.addEventListener('DOMContentLoaded', () => {
                document.getElementById('icon-moon').classList.add('hidden');
                document.getElementById('icon-sun').classList.remove('hidden');
            });
        }

        let currentDeleteFormId = null;
        const deleteModal = document.getElementById('deleteModal');
        const deleteModalContent = document.getElementById('deleteModalContent');

        function openDeleteModal(empId) {
            currentDeleteFormId = 'delete-form-' + empId;
            deleteModal.classList.remove('hidden');
            deleteModal.classList.add('flex');
            
            setTimeout(() => {
                deleteModalContent.classList.remove('scale-95', 'opacity-0');
                deleteModalContent.classList.add('scale-100', 'opacity-100');
            }, 10);
        }

        function closeDeleteModal() {
            deleteModalContent.classList.remove('scale-100', 'opacity-100');
            deleteModalContent.classList.add('scale-95', 'opacity-0');
            
            setTimeout(() => {
                deleteModal.classList.add('hidden');
                deleteModal.classList.remove('flex');
                currentDeleteFormId = null;
            }, 200); 
        }

        function confirmDelete() {
            if (currentDeleteFormId) {
                document.getElementById(currentDeleteFormId).submit();
            }
        }
    </script>
</body>
</html>