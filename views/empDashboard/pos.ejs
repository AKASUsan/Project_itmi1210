<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../head') %>
</head>

<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 transition-colors duration-300 min-h-screen font-sans overflow-hidden">
  
  <div id="notification" 
       class="fixed top-6 right-6 z-[999] pointer-events-none opacity-0 translate-x-10 transition-all duration-300">
    <div id="notification-content" class="flex items-center gap-3 px-6 py-4 rounded-2xl shadow-2xl border min-w-[300px] bg-zinc-900 border-white/10 text-white">
      <div id="notification-icon-bg" class="p-2 rounded-xl">
        <i id="notification-icon" class="w-5 h-5 text-white"></i>
      </div>
      <div>
        <p id="notification-status" class="text-[10px] leading-none mb-1 font-black tracking-widest"></p>
        <p id="notification-message" class="text-white font-bold text-sm"></p>
      </div>
    </div>
  </div>

  <div class="flex h-screen p-4 gap-4">
    <%- include('navbarpos') %>

    <main class="flex-1 flex flex-col min-w-0 space-y-6 p-4">
      <header class="flex justify-between items-center pb-6 border-b border-gray-200 dark:border-white/5">
        <div>
          <h1 class="text-2xl font-black uppercase tracking-tight text-gray-900 dark:text-white">POS Terminal</h1>
          <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[2px]">Order Management</p>
        </div>
        
        <div class="flex items-center gap-4">
          <button onclick="toggleTheme()" class="p-2 text-gray-600 dark:text-white hover:bg-gray-200 dark:hover:bg-white/20 rounded-full transition duration-300">
            <i data-lucide="sun" class="w-5 h-5 hidden dark:block"></i>
            <i data-lucide="moon" class="w-5 h-5 dark:hidden"></i>
          </button>
          
          <div class="relative" x-data="{ open: false }">
            <% 
              const userImg = (user && user.image) ? user.image : 'default.jpg';
              const empName = (employee && employee.name) ? employee.name : 'Staff';
              const imgPath = (user && (user.role === 'admin' || user.role === 'staff')) ? '/images/employeeProfile/' : '/images/profile/'; 
            %>
            <button @click.stop="open = !open" class="flex items-center gap-3 p-1 pr-3 bg-white dark:bg-zinc-800 rounded-full border border-gray-200 dark:border-zinc-700 shadow-sm">
              <img src="<%= imgPath %><%= userImg %>" class="w-8 h-8 rounded-full object-cover border-2 border-orange-500" />
              <span class="text-gray-800 dark:text-white text-sm font-medium hidden sm:block uppercase"><%= empName %></span>
              <i data-lucide="chevron-down" class="text-gray-400 text-[10px] transition-transform" :class="open ? 'rotate-90' : ''"></i>
            </button>

            <div x-show="open" @click.away="open = false" x-transition class="absolute right-0 mt-3 w-56 origin-top-right rounded-2xl bg-white dark:bg-zinc-900 shadow-xl border border-gray-100 dark:border-zinc-800 z-[110] overflow-hidden" style="display: none">
                <div class="px-4 py-3 bg-emerald-500/10 border-b border-gray-100 dark:border-zinc-800">
                  <p class="text-xs text-gray-500 dark:text-gray-400">Role Sign</p>
                  <p class="text-sm font-bold text-orange-600 dark:text-orange-400 truncate uppercase"><%= employee.role %></p>
                </div>
                <div class="py-1">
                 <a href="/" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-orange-50 dark:hover:bg-white/5 transition">
                  <i data-lucide="house" class="text-orange-500 w-5"></i> Home
                </a>
                <a href="/logout" class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 transition font-bold">
                  <i data-lucide="log-out" class="w-5"></i> Sign Out
                </a>
              </div>
            </div>
          </div>
        </div>
      </header>

      <div class="flex-1 flex gap-6 overflow-hidden">
        <div class="flex-[2.5] flex flex-col space-y-4 min-w-0">
          <div class="flex-1 overflow-y-auto pr-2 grid grid-cols-2 xl:grid-cols-4 gap-4 content-start" id="posProductGrid">
            <% products.forEach(product => { %>
              <div onclick="addToCart('<%= product._id %>', '<%= product.name %>', '<%= product.price %>')" 
                   class="group bg-white dark:bg-zinc-900 p-4 rounded-[2rem] border border-zinc-200 dark:border-zinc-800 hover:border-orange-500 transition-all cursor-pointer relative overflow-hidden">
                <div class="aspect-square bg-zinc-100 dark:bg-zinc-800 rounded-2xl mb-3 overflow-hidden">
                  <img src="/images/product/<%= product.image %>" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-500" onerror="this.src='/images/default.jpg'">
                </div>
                <h3 class="text-[11px] font-black truncate dark:text-white uppercase"><%= product.name %></h3>
                <p class="text-orange-500 font-black text-sm mt-1">฿<%= product.price.toLocaleString() %></p>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="flex-1 bg-white dark:bg-zinc-900 rounded-[2.5rem] border border-zinc-200 dark:border-zinc-800 shadow-xl flex flex-col overflow-hidden">
          <div class="p-6 border-b dark:border-zinc-800 flex justify-between items-center">
            <h3 class="text-[10px] font-black uppercase tracking-[2px] flex items-center gap-2">
              <span class="w-1 h-4 bg-orange-500 rounded-full"></span> Current Order
            </h3>
            <button onclick="clearCart()" class="text-[9px] text-zinc-400 hover:text-red-500 uppercase font-bold">Clear</button>
          </div>
          
          <div class="flex-1 overflow-y-auto p-4 space-y-3" id="cartItems">
             <div class="h-full flex flex-col items-center justify-center opacity-20 py-10">
                <i data-lucide="shopping-basket" class="w-12 h-12 mb-2"></i>
                <p class="text-[10px] font-bold uppercase">Empty Cart</p>
             </div>
          </div>

        <div class="px-6 py-4 bg-orange-500/5 border-t border-zinc-100 dark:border-zinc-800">
             <p class="text-[9px] text-orange-600 dark:text-orange-400 uppercase font-black mb-2">Member Phone</p>
            <div class="relative group">
             <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
               <i data-lucide="phone" class="w-4 h-4 text-orange-500/70 group-focus-within:text-orange-500 transition-colors"></i>
             </div>
  
            <input type="text" 
            id="memberPhone" 
            maxlength="10" 
            placeholder="Enter Phone Number"
            class="w-full bg-white dark:bg-zinc-800/50 border border-orange-200 dark:border-orange-900/30 text-[11px] font-bold rounded-xl pl-10 pr-4 py-2.5 outline-none focus:ring-2 ring-orange-500/20 focus:border-orange-500/50 transition-all placeholder:text-zinc-500/50">
        </div>
          </div>

          <div class="p-6 bg-zinc-50 dark:bg-zinc-800/30 border-t dark:border-zinc-800">
            <div class="grid grid-cols-2 gap-2">
              <button onclick="setPayment('cash')" id="payCash" class="payment-btn flex flex-col items-center gap-1 py-3 rounded-2xl border-2 border-zinc-200 dark:border-zinc-700 text-[10px] font-bold uppercase transition-all">
                <i data-lucide="banknote" class="w-4 h-4"></i> Cash
              </button>
              <button onclick="setPayment('qr')" id="payQR" class="payment-btn flex flex-col items-center gap-1 py-3 rounded-2xl border-2 border-zinc-200 dark:border-zinc-700 text-[10px] font-bold uppercase transition-all">
                <i data-lucide="qr-code" class="w-4 h-4"></i> QR Code
              </button>
            </div>
          </div>

          <div class="p-6 border-t dark:border-zinc-800">
            <div class="flex justify-between items-center mb-4">
              <span class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Total Amount</span>
              <p class="text-2xl font-black tracking-tighter text-zinc-900 dark:text-white">฿ <span id="cartTotalPrice">0.00</span></p>
            </div>
            <button onclick="checkout()" id="checkoutBtn" disabled class="w-full bg-orange-600 hover:bg-orange-500 disabled:bg-zinc-200 dark:disabled:bg-zinc-800 text-white font-black py-4 rounded-2xl transition-all uppercase text-[10px] tracking-[3px]">
              Confirm Order
            </button>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
  <script>
    lucide.createIcons();
    let cart = [];
    let selectedPayment = '';

    // ฟังก์ชันแจ้งเตือน (Toast) แบบใช้แต่คลาส Tailwind
    function showToast(message, status = 'success') {
      const toast = document.getElementById('notification');
      const icon = document.getElementById('notification-icon');
      const iconBg = document.getElementById('notification-icon-bg');
      const statusText = document.getElementById('notification-status');
      const msgText = document.getElementById('notification-message');

      if (status === 'success') {
        iconBg.className = "p-2 rounded-xl bg-emerald-500";
        icon.setAttribute('data-lucide', 'check');
        statusText.innerText = "SUCCESS";
        statusText.className = "text-[10px] text-emerald-400 font-black";
      } else {
        iconBg.className = "p-2 rounded-xl bg-red-500";
        icon.setAttribute('data-lucide', 'x');
        statusText.innerText = "ERROR";
        statusText.className = "text-[10px] text-red-400 font-black";
      }

      msgText.innerText = message;
      lucide.createIcons();
      
      toast.classList.remove('opacity-0', 'translate-x-10');
      toast.classList.add('opacity-100', 'translate-x-0');

      setTimeout(() => {
        toast.classList.remove('opacity-100', 'translate-x-0');
        toast.classList.add('opacity-0', 'translate-x-10');
      }, 3000);
    }

    function addToCart(id, name, price) {
        const item = cart.find(i => i.id === id);
        if (item) { item.qty++; } 
        else { cart.push({ id, name, price: Number(price), qty: 1 }); }
        renderCart();
    }

    function updateQty(index, delta) {
        cart[index].qty += delta;
        if (cart[index].qty <= 0) { cart.splice(index, 1); }
        renderCart();
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        renderCart();
    }

    function clearCart() {
        cart = [];
        document.getElementById('memberPhone').value = '';
        renderCart();
    }

    function setPayment(method) {
        selectedPayment = method;
        document.querySelectorAll('.payment-btn').forEach(btn => {
            btn.classList.remove('border-orange-500', 'bg-orange-500/10', 'text-orange-600');
            btn.classList.add('border-zinc-200', 'dark:border-zinc-700');
        });
        const activeBtn = method === 'cash' ? document.getElementById('payCash') : document.getElementById('payQR');
        activeBtn.classList.add('border-orange-500', 'bg-orange-500/10', 'text-orange-600');
        checkCheckout();
    }

    function checkCheckout() {
        const btn = document.getElementById('checkoutBtn');
        btn.disabled = (cart.length === 0 || selectedPayment === '');
    }

    function renderCart() {
        const list = document.getElementById('cartItems');
        let total = 0;
        if (cart.length === 0) {
            list.innerHTML = `<div class="h-full flex flex-col items-center justify-center opacity-20 py-10"><i data-lucide="shopping-basket" class="w-12 h-12 mb-2"></i><p class="text-[10px] font-bold uppercase">Empty Cart</p></div>`;
        } else {
            list.innerHTML = cart.map((item, idx) => {
                total += item.price * item.qty;
                return `
                <div class="flex justify-between items-center bg-zinc-50 dark:bg-zinc-800/50 p-3 rounded-2xl border border-zinc-100 dark:border-zinc-700 text-[10px] font-black uppercase mb-2">
                    <div class="flex-1 truncate pr-2">
                        <div class="text-zinc-900 dark:text-white">${item.name}</div>
                        <div class="text-orange-500 mt-0.5">฿${(item.price * item.qty).toLocaleString()}</div>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="flex items-center bg-white dark:bg-zinc-900 rounded-lg p-0.5 border dark:border-zinc-700">
                            <button onclick="updateQty(${idx}, -1)" class="w-5 h-5 flex items-center justify-center">-</button>
                            <span class="w-6 text-center text-xs font-bold">${item.qty}</span>
                            <button onclick="updateQty(${idx}, 1)" class="w-5 h-5 flex items-center justify-center">+</button>
                        </div>
                        <button onclick="removeFromCart(${idx})" class="p-1.5 text-zinc-400 hover:text-red-500"><i data-lucide="trash-2" class="w-3.5 h-3.5"></i></button>
                    </div>
                </div>`;
            }).join('');
        }
        document.getElementById('cartTotalPrice').innerText = total.toLocaleString(undefined, {minimumFractionDigits: 2});
        lucide.createIcons();
        checkCheckout();
    }

    async function checkout() {
        const btn = document.getElementById('checkoutBtn');
        const phone = document.getElementById('memberPhone').value;
        const total = cart.reduce((sum, i) => sum + (i.price * i.qty), 0);
        const totalQty = cart.reduce((sum, i) => sum + i.qty, 0);

        const formattedItems = cart.map(item => ({
            menuName: item.name, 
            quantity: item.qty,
            price: item.price
        }));

        btn.disabled = true;
        btn.innerText = "PROCESSING...";

        try {
            const response = await fetch('/pos/checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    items: formattedItems,
                    totalAmount: total,
                    paymentMethod: selectedPayment,
                    customerPhone: phone,
                    pointsToAdd: totalQty
                })
            });

            if (response.ok) {
                showToast("Order Placed Successfully!", "success");
                clearCart();
                selectedPayment = '';
                document.querySelectorAll('.payment-btn').forEach(b => {
                    b.classList.remove('border-orange-500', 'bg-orange-500/10', 'text-orange-600');
                    b.classList.add('border-zinc-200', 'dark:border-zinc-700');
                });
                btn.innerText = "CONFIRM ORDER";
            } else {
                const errData = await response.json();
                showToast(errData.message || "Failed", "error");
                btn.disabled = false;
                btn.innerText = "CONFIRM ORDER";
            }
        } catch (error) {
            showToast("Network Error", "error");
            btn.disabled = false;
            btn.innerText = "CONFIRM ORDER";
        }
    }

    function toggleTheme() {
        document.documentElement.classList.toggle('dark');
        lucide.createIcons();
    }
  </script>
</body>
</html>