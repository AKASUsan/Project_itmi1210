<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
</head>
<body class="bg-[#050505] text-white font-sans">

    <div class="max-w-7xl mx-auto p-4 md:p-8">
        <header class="flex items-center gap-4 mb-8">
            <a href="/cart" class="p-2 hover:bg-white/10 rounded-full transition">
                <i data-lucide="arrow-left" class="w-6 h-6"></i>
            </a>
            <div>
                <h1 class="text-2xl font-black uppercase tracking-tight">Checkout</h1>
                <p class="text-[10px] text-gray-500 font-bold uppercase tracking-[2px]">Secure your order</p>
            </div>
        </header>

        <form action="/checkout/process" method="POST" class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            
            <div class="lg:col-span-8 space-y-6">
                
                <section class="bg-[#1a1a1a] border border-white/5 rounded-3xl p-6 md:p-8">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="p-2 bg-orange-500/10 rounded-lg">
                            <i data-lucide="truck" class="w-5 h-5 text-orange-500"></i>
                        </div>
                        <h2 class="text-lg font-bold">Shipping Details</h2>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label class="text-[10px] uppercase font-bold text-gray-500 ml-1">Full Name</label>
                            <input type="text" name="name" value="<%= user.name %>" required
                                class="w-full bg-black/40 border border-white/10 rounded-2xl p-4 focus:border-orange-500 outline-none transition">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] uppercase font-bold text-gray-500 ml-1">Phone Number</label>
                            <input type="tel" name="phone"  value="<%= user.phone %>"required
                                class="w-full bg-black/40 border border-white/10 rounded-2xl p-4 focus:border-orange-500 outline-none transition">
                        </div>
                        <div class="md:col-span-2 space-y-2">
                            <label class="text-[10px] uppercase font-bold text-gray-500 ml-1">Shipping Address</label>
                            <textarea name="address" required rows="3"
                                class="w-full bg-black/40 border border-white/10 rounded-2xl p-4 focus:border-orange-500 outline-none transition"><%= user.address || '' %></textarea>
                        </div>
                    </div>
                </section>

                <section class="bg-[#1a1a1a] border border-white/5 rounded-3xl p-6 md:p-8">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="p-2 bg-emerald-500/10 rounded-lg">
                            <i data-lucide="credit-card" class="w-5 h-5 text-emerald-500"></i>
                        </div>
                        <h2 class="text-lg font-bold">Payment Method</h2>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4" x-data="{ method: 'qr' }">
                        <label class="cursor-pointer">
                            <input type="radio" name="paymentMethod" value="qr" class="hidden peer" x-model="method">
                            <div class="peer-checked:border-orange-500 peer-checked:bg-orange-500/5 border border-white/5 rounded-2xl p-6 text-center transition hover:bg-white/5">
                                <i data-lucide="qr-code" class="mx-auto mb-3 w-8 h-8 opacity-50 peer-checked:opacity-100"></i>
                                <span class="block text-sm font-bold uppercase tracking-tight">QR Code</span>
                            </div>
                        </label>

                        <label class="cursor-pointer">
                            <input type="radio" name="paymentMethod" value="card" class="hidden peer" x-model="method">
                            <div class="peer-checked:border-orange-500 peer-checked:bg-orange-500/5 border border-white/5 rounded-2xl p-6 text-center transition hover:bg-white/5">
                                <i data-lucide="credit-card" class="mx-auto mb-3 w-8 h-8 opacity-50 peer-checked:opacity-100"></i>
                                <span class="block text-sm font-bold uppercase tracking-tight">Credit Card</span>
                            </div>
                        </label>

                        <label class="cursor-pointer">
                            <input type="radio" name="paymentMethod" value="cash" class="hidden peer" x-model="method">
                            <div class="peer-checked:border-orange-500 peer-checked:bg-orange-500/5 border border-white/5 rounded-2xl p-6 text-center transition hover:bg-white/5">
                                <i data-lucide="banknote" class="mx-auto mb-3 w-8 h-8 opacity-50 peer-checked:opacity-100"></i>
                                <span class="block text-sm font-bold uppercase tracking-tight">Cash</span>
                            </div>
                        </label>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-4">
                <div class="bg-[#1a1a1a] border border-white/5 rounded-3xl p-6 md:p-8 sticky top-8">
                    <h2 class="text-lg font-bold mb-6">Order Summary</h2>
                    
                    <div class="space-y-4 mb-8">
                        <% cartItems.forEach(item => { %>
                        <div class="flex justify-between items-center">
                            <div class="flex items-center gap-3">
                                <div class="w-12 h-12 bg-black rounded-xl border border-white/5 overflow-hidden">
                                   <img src="/images/product/<%= item.image %>" class="w-full h-full object-cover bg-gray-100">
                                </div>
                                <div>
                                    <p class="text-sm font-bold"><%= item.name %></p>
                                    <p class="text-[10px] text-gray-500">Qty: <%= item.quantity %></p>
                                </div>
                            </div>
                            <p class="text-sm font-bold">฿<%= (item.price * item.quantity).toLocaleString() %></p>
                        </div>
                        <% }) %>
                    </div>

                    <div class="space-y-3 border-t border-white/5 pt-6 mb-8">
                        <div class="flex justify-between text-gray-500 text-sm">
                            <span>Subtotal</span>
                            <span>฿<%= subtotal.toLocaleString() %></span>
                        </div>
                        <div class="flex justify-between text-gray-500 text-sm">
                            <span>Shipping</span>
                            <span class="text-emerald-500 italic">Free</span>
                        </div>
                        <div class="flex justify-between text-xl font-black pt-2">
                            <span>Total</span>
                            <span class="text-orange-500">฿<%= total.toLocaleString() %></span>
                        </div>
                    </div>

                    <button type="submit" 
                        class="w-full bg-orange-500 hover:bg-orange-600 text-white font-black py-5 rounded-2xl transition shadow-xl shadow-orange-500/20 uppercase tracking-widest text-sm">
                        Complete Order
                    </button>

                    <div class="mt-6 flex items-center justify-center gap-2 text-gray-500">
                        <i data-lucide="shield-check" class="w-4 h-4"></i>
                        <span class="text-[10px] font-bold uppercase tracking-wider">Secure Payment Gateway</span>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <script>
        lucide.createIcons();
        
         if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
</body>
</html>