<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../head.ejs') %>
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.2.2/dist/js/tom-select.complete.min.js"></script>
</head>
<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 min-h-screen font-sans">
    <div class="flex flex-col min-h-screen">
        <main class="p-4 md:p-10 flex-grow">
            <div class="max-w-3xl mx-auto">
                <div class="mb-8 flex items-center gap-4">
                    <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 font-medium group">
                        <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                        Back
                    </button>
                    <h1 class="text-3xl font-black tracking-wide text-zinc-900 dark:text-zinc-100 uppercase">
                        Add <span class="text-kaizen-orange">Promotion</span>
                    </h1>
                </div>

                <div class="bg-white dark:bg-kaizen-dark border border-kaizen-tan dark:border-zinc-800 rounded-2xl shadow-sm p-6 md:p-8">
                    <form action="/promotions/add" method="POST" enctype="multipart/form-data" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="md:col-span-2">
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Promotion Title</label>
                                <input type="text" name="title" required class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange">
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Select Bundle Menus (Minimum 2)</label>
                                <select name="applicableItems" id="menu-select" multiple placeholder="Search and select menus..." autocomplete="off" required>
                                    <% products.forEach(menu => { %>
                                        <option value="<%= menu._id %>" data-price="<%= menu.price %>">
                                            <%= menu.name %> (฿<%= menu.price %>)
                                        </option>
                                    <% }) %>
                                </select>
                                <p id="menu-error" class="text-xs text-red-500 mt-2 hidden">Please select at least 2 menus for this bundle.</p>
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Original Total (฿)</label>
                                <input type="number" name="originalPrice" id="originalPrice" readonly class="w-full px-4 py-3 rounded-xl bg-gray-100 dark:bg-zinc-800/50 border border-kaizen-tan dark:border-zinc-700 cursor-not-allowed font-bold text-kaizen-orange">
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Discount (%)</label>
                                <input type="number" name="discountPercent" id="discountPercent" min="0" max="100" placeholder="0" class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange">
                            </div>

                            <div class="md:col-span-2 p-5 bg-orange-50 dark:bg-orange-900/10 border border-orange-200 dark:border-orange-800/40 rounded-2xl flex justify-between items-center">
                                <div>
                                    <p class="text-xs font-bold text-orange-600 dark:text-orange-400 uppercase tracking-widest mb-1">Final Promo Price</p>
                                    <p class="text-4xl font-black text-kaizen-orange">฿ <span id="finalPriceDisplay">0</span></p>
                                </div>
                                <i data-lucide="tag" class="w-10 h-10 text-kaizen-orange opacity-20"></i>
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Banner Image</label>
                                <input type="file" name="imageFilename" required accept="image/*" class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-kaizen-orange file:text-white">
                            </div>

                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Start Date</label>
                                <input type="date" name="startDate" required class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange [color-scheme:dark]">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">End Date</label>
                                <input type="date" name="endDate" required class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange [color-scheme:dark]">
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Description</label>
                                <textarea name="description" rows="3" class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange"></textarea>
                            </div>
                        </div>

                        <div class="flex items-center gap-3">
                            <input type="checkbox" name="isActive" id="isActive" checked class="w-5 h-5 accent-kaizen-orange rounded">
                            <label for="isActive" class="text-sm font-bold text-zinc-700 dark:text-zinc-300 cursor-pointer">Active</label>
                        </div>

                        <div class="pt-6 border-t border-kaizen-tan dark:border-zinc-800 flex justify-end gap-4">
                            <a href="/promotions" class="px-6 py-3 rounded-xl font-bold text-zinc-500 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">Cancel</a>
                            <button type="submit" class="bg-kaizen-orange hover:bg-orange-600 text-white font-bold py-3 px-8 rounded-xl shadow-md flex items-center gap-2 active:scale-95 transition-all">
                                <i data-lucide="save" class="w-4 h-4"></i> SAVE PROMOTION
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <script>
        lucide.createIcons();

        const menuSelect = new TomSelect('#menu-select', {
            plugins: ['remove_button'],
            onItemAdd: function() { this.setTextboxValue(''); calculate(); },
            onItemRemove: function() { calculate(); }
        });

        document.querySelectorAll('#menu-select option').forEach(opt => {
            if(menuSelect.options[opt.value]) {
                menuSelect.options[opt.value].price = opt.dataset.price;
            }
        });

        const priceIn = document.getElementById('originalPrice');
        const discIn = document.getElementById('discountPercent');
        const display = document.getElementById('finalPriceDisplay');
        const menuError = document.getElementById('menu-error');

        function calculate() {
            const selectedIds = menuSelect.getValue();
            let total = 0;
            selectedIds.forEach(id => {
                total += parseFloat(menuSelect.options[id].price || 0);
            });
            
            priceIn.value = total;
            const d = parseFloat(discIn.value) || 0;
            const final = total - (total * (d / 100));
            display.innerText = final.toLocaleString(undefined, {minimumFractionDigits: 0, maximumFractionDigits: 2});

            if(selectedIds.length > 0 && selectedIds.length < 2) {
                menuError.classList.remove('hidden');
            } else {
                menuError.classList.add('hidden');
            }
        }

        discIn.addEventListener('input', calculate);

        document.querySelector('form').addEventListener('submit', (e) => {
            if (menuSelect.getValue().length < 2) {
                e.preventDefault();
                alert('Please select at least 2 menus.');
            }
        });
    </script>
</body>
</html>