<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../head.ejs') %>
</head>
<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 transition-colors duration-300 min-h-screen font-sans">
    <div class="flex flex-col min-h-screen">
        <main class="p-4 md:p-10 flex-grow">
            
            <div class="max-w-6xl mx-auto">
               <div class="mb-6">
                        <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                            <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                            Back
                        </button>
                    </div>
                <div class="mb-8 flex items-center justify-between">
                    <div>
                        <h1 class="text-3xl font-black tracking-wide text-zinc-900 dark:text-zinc-100 uppercase">
                            PROMOTION <span class="text-kaizen-orange">MANAGEMENT</span>
                        </h1>
                    </div>
                    <a href="/promotions/add" class="bg-[#1db954] text-white px-6 py-2.5 rounded-full font-bold uppercase tracking-wider text-sm flex items-center gap-2 hover:bg-[#189945] transition shadow-sm">
                        <i data-lucide="plus" class="w-5 h-5"></i> NEW PROMOTION
                    </a>
                </div>

                <div class="bg-white dark:bg-kaizen-dark border border-kaizen-tan dark:border-zinc-800 rounded-2xl shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="border-b border-kaizen-tan dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/50">
                                    <th class="py-4 px-6 font-bold text-xs text-zinc-500 uppercase tracking-wider">Promotion Info</th>
                                    <th class="py-4 px-6 font-bold text-xs text-zinc-500 uppercase tracking-wider text-center">Status</th>
                                    <th class="py-4 px-6 font-bold text-xs text-zinc-500 uppercase tracking-wider text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (promotions && promotions.length > 0) { %>
                                    <% promotions.forEach(promo => { %>
                                    <tr class="border-b border-zinc-100 dark:border-zinc-800/50 hover:bg-zinc-50 dark:hover:bg-zinc-800/20 transition">
                                        <td class="py-4 px-6">
                                            <div class="flex items-center gap-4">
                                                <div class="w-16 h-12 rounded-lg bg-zinc-100 dark:bg-zinc-800 overflow-hidden flex-shrink-0 border border-kaizen-tan dark:border-zinc-700">
                                                    <img src="/images/promotions/<%= promo.imageFilename %>" alt="Banner" class="w-full h-full object-cover">
                                                </div>
                                                <div>
                                                    <p class="font-bold text-zinc-900 dark:text-white"><%= promo.title %></p>
                                                    <p class="text-xs text-zinc-500 mt-1">
                                                        <%= promo.startDate ? new Date(promo.startDate).toLocaleDateString() : 'N/A' %> 
                                                        - 
                                                        <%= promo.endDate ? new Date(promo.endDate).toLocaleDateString() : 'N/A' %>
                                                    </p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="py-4 px-6 text-center">
                                            <% if (promo.isActive) { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> ACTIVE
                                                </span>
                                            <% } else { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                                                    <span class="w-1.5 h-1.5 rounded-full bg-zinc-500"></span> INACTIVE
                                                </span>
                                            <% } %>
                                        </td>
                                        <td class="py-4 px-6 text-right">
                                            <div class="flex items-center justify-end gap-2">
                                                <form action="/promotions/delete/<%= promo._id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this promotion?');">
                                                    <button type="submit" class="p-2 text-zinc-500 hover:text-kaizen-red hover:bg-red-50 dark:hover:bg-red-950/30 rounded-lg transition">
                                                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" class="py-8 text-center text-zinc-500 font-medium">No promotions found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </main>
    </div>
    <script>
        lucide.createIcons();
        if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
</body>
</html>