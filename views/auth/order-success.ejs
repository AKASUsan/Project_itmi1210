<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head') %>
</head>
<body class="bg-[#050505] text-white font-sans flex items-center justify-center min-h-screen">

    <div class="text-center bg-[#1a1a1a] p-10 md:p-16 rounded-3xl border border-white/5 max-w-lg w-full mx-4">
        <div class="w-20 h-20 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <i data-lucide="check-circle" class="w-10 h-10 text-emerald-500"></i>
        </div>
        
        <h1 class="text-3xl font-black uppercase tracking-tight mb-2">Order Success!</h1>
        <p class="text-gray-400 text-sm mb-8">Your order has been placed successfully.</p>
        
        <div class="bg-black/40 rounded-2xl p-4 mb-8 border border-white/5">
            <p class="text-[10px] text-gray-500 font-bold uppercase tracking-wider mb-1">Order ID</p>
            <p class="font-mono text-sm text-orange-500"><%= order._id %></p>
        </div>

        <a href="/" class="block w-full bg-white hover:bg-gray-200 text-black font-black py-4 rounded-2xl transition uppercase tracking-widest text-sm">
            Back to Home
        </a>
    </div>

    <script>
        lucide.createIcons();
        
         if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }
    </script>
</body>
</html>