</div>

<button onclick="toggleMobileSearch()" class="sm:hidden w-9 h-9 text-white hover:bg-white/20 rounded-full transition duration-300 flex items-center justify-center mr-2">
    <i data-lucide="search" class="w-5 h-5"></i>
