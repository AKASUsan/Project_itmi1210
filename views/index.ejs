<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('head.ejs') %>
</head>

<body class="bg-white text-gray-900 dark:bg-gray-900 dark:text-white">
    <%- include('navbar.ejs') %>

    <div class="relative h-screen w-full overflow-hidden flex items-center justify-center">
        <div class="absolute inset-0 bg-[url(/images/background/ramen-b.jpg)] bg-cover bg-center brightness-75 opacity-30 dark:opacity-100 dark:brightness-50 blur-[2px] scale-105 transition-all duration-700"></div>
        <div class="relative z-10 text-center px-6 max-w-5xl" data-aos="zoom-in" data-aos-duration="1000">
            <p class="text-orange-600 dark:text-orange-400 text-lg md:text-xl tracking-[0.3em] uppercase mb-4 font-bold">Crafting Perfection in Every Bowl</p>
            <h1 class="text-7xl md:text-9xl macondo-regular leading-none mb-2 drop-shadow-md">Welcome To</h1>
            <h1 class="text-6xl md:text-8xl macondo-regular mb-10 tracking-tight drop-shadow-md">KAIZEN RAMEN</h1>
            <p class="text-lg md:text-2xl mb-12 font-light max-w-3xl mx-auto leading-relaxed italic opacity-80">
                "The art of continuous improvement, served in a bowl of 18-hour slow-cooked broth and artisanal handmade noodles."
            </p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
                <a href="/menu" class="group relative px-10 py-4 bg-red-600 hover:bg-red-700 text-white rounded-full transition-all duration-300 font-bold text-lg shadow-xl hover:scale-110 active:scale-95 overflow-hidden">
                    <span class="relative z-10">EXPLORE MENU</span>
                </a>
                <a href="#reservation" class="px-10 py-4 bg-transparent border-2 border-orange-600 dark:border-white hover:bg-orange-600 dark:hover:bg-white hover:text-white dark:hover:text-black rounded-full transition-all duration-300 font-bold text-lg backdrop-blur-sm">BOOK A TABLE</a>
            </div>
        </div>
    </div>

    <div class="relative flex flex-col items-center justify-center py-20 overflow-hidden">
        <div class="absolute select-none pointer-events-none text-[8rem] md:text-[12rem] font-black uppercase tracking-widest text-gray-500/[0.05] dark:text-white/[0.03] leading-none">DELICIOUS</div>
        <div class="relative z-10 flex flex-col items-center" data-aos="fade-up">
            <div class="flex items-center space-x-3 mb-2">
                <div class="h-[2px] w-8 bg-orange-600"></div>
                <span class="text-orange-600 dark:text-orange-500 font-bold uppercase tracking-[0.4em] text-xs md:text-sm">Authentic Taste</span>
                <div class="h-[2px] w-8 bg-orange-600"></div>
            </div>
            <h2 class="text-5xl md:text-7xl font-black text-gray-900 dark:text-white uppercase tracking-tighter">OUR <span class="text-orange-600">MENU</span></h2>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 px-6 max-w-7xl mx-auto py-10">
        <% Object.values(products).slice(0, 3).forEach(function(item){ %>
        <div class="group relative flex flex-col items-center bg-white dark:bg-gray-800/40 p-8 rounded-[2.5rem] border border-gray-100 dark:border-gray-700/50 transition-all duration-500 hover:shadow-[0_20px_50px_rgba(234,88,12,0.15)] hover:-translate-y-3 backdrop-blur-md" data-aos="fade-up">
            <div class="relative z-10 mb-8">
                <a href="/product/<%= item._id %>" class="block h-48 w-48 md:h-56 md:w-56 overflow-hidden rounded-full border-4 border-white dark:border-gray-700 p-2 shadow-xl group-hover:border-orange-500 transition-all duration-500">
                    <img src="/images/product/<%= item.image %>" alt="<%= item.name %>" class="h-full w-full rounded-full object-cover transition-transform duration-700 group-hover:scale-110 group-hover:rotate-3">
                </a>
            </div>
            <div class="relative z-10 text-center w-full">
                <a href="/product/<%= item._id %>">
                    <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-orange-600 transition-colors duration-300"><%= item.name %></h3>
                </a>
                <div class="mt-3 flex items-center justify-center space-x-1">
                    <span class="text-sm font-bold text-orange-600">฿</span>
                    <span class="text-3xl font-black text-gray-900 dark:text-white leading-none"><%= item.price %></span>
                </div>
                <div class="mx-auto my-5 h-1 w-10 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden transition-all duration-500 group-hover:w-20">
                    <div class="h-full w-0 bg-orange-600 group-hover:w-full transition-all duration-700 delay-100"></div>
                </div>
                <button onclick="addToCart('<%= item._id %>')" class="relative w-full py-3 px-6 bg-gray-900 dark:bg-white text-white dark:text-black rounded-2xl font-black text-sm tracking-widest uppercase overflow-hidden transition-all duration-300 active:scale-95 group-hover:bg-orange-600 group-hover:text-white shadow-lg">
                    <span class="relative z-10"><%= locals.user ? 'Add to Order' : 'Sign in to Order' %></span>
                </button>
            </div>
        </div>
        <% }) %>
    </div>

   <section id="promo-section" class="py-20 px-6 bg-slate-50 dark:bg-[#0f0f0f] <%= promotions.length === 0 ? 'hidden' : '' %>">
    <div id="promo-container" class="max-w-6xl mx-auto w-full">
        <% promotions.forEach((promo, index) => { %>
            <div class="promo-item <%= index === 0 ? '' : 'hidden' %> relative overflow-hidden rounded-3xl bg-white shadow-xl dark:bg-gray-900 border border-gray-100 dark:border-gray-800 transition-all duration-500" data-index="<%= index %>">
                <div class="grid grid-cols-1 md:grid-cols-2">
                    <div class="p-10 md:p-16 flex flex-col justify-center">
                        <div class="flex flex-wrap items-center gap-3 mb-4">
                            <span class="inline-block px-3 py-1 rounded-full bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 text-xs font-bold uppercase tracking-widest">
                                <%= promo.discountPercent %>% OFF
                            </span>
                        </div>
                        <h2 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white mb-4 uppercase">
                            <%= promo.title %>
                        </h2>
                        <div class="mb-6 flex items-baseline gap-4">
                            <span class="text-4xl md:text-5xl font-black text-orange-600">
                                ฿<%= (promo.discountedPrice || 0).toLocaleString() %>
                            </span>
                            <span class="text-xl text-gray-400 line-through">
                                ฿<%= (promo.originalPrice || 0).toLocaleString() %>
                            </span>
                        </div>
                        <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
                            <%= promo.description %>
                        </p>
                       <button onclick="addToCart(null, '<%= promo._id %>')" class="w-fit px-10 py-4 bg-orange-600 text-white font-black rounded-2xl hover:scale-105 active:scale-95 transition-all shadow-lg uppercase text-sm">
                        <span class="relative z-10"><%= locals.user ? 'CLAIM THIS DEAL' : 'Sign in to Order' %></span>
                        </button>
                        
                    </div>
                    <div class="relative h-72 md:h-auto bg-gray-200 dark:bg-gray-800 overflow-hidden">
                        <img src="/images/promotions/<%= promo.imageFilename %>" class="absolute inset-0 w-full h-full object-cover" alt="<%= promo.title %>">
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</section>

    <section class="py-24 bg-orange-50/50 dark:bg-[#0c0c0c]">
        <div class="max-w-6xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
                <div>
                    <span class="text-orange-600 font-bold tracking-widest uppercase text-sm">Highly Recommended</span>
                    <h2 class="text-4xl font-black text-gray-900 dark:text-white mt-2">CHEF'S <span class="text-orange-600">SELECTION</span></h2>
                </div>
                <p class="text-gray-500 dark:text-gray-400 max-w-md">เมนูพิเศษที่เชฟคัดสรรวัตถุดิบที่ดีที่สุดในแต่ละวัน เพื่อส่งมอบรสชาติระดับพรีเมียมให้คุณ</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <% Object.values(products).slice(0, 2).forEach(function(item){ %>
                <div class="group relative flex flex-col sm:flex-row bg-white dark:bg-gray-900 rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-gray-800">
                    <div class="w-full sm:w-1/2 h-64 sm:h-auto overflow-hidden">
                        <a href="/product/<%= item._id %>">
                            <img src="/images/product/<%= item.image %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" alt="<%= item.name %>">
                        </a>
                    </div>
                    <div class="p-8 flex flex-col justify-between sm:w-1/2">
                        <div>
                            <div class="flex justify-between items-start mb-2">
                                <a href="/product/<%= item._id %>">
                                    <h3 class="text-xl font-bold text-gray-900 dark:text-white leading-tight hover:text-orange-600"><%= item.name %></h3>
                                </a>
                                <span class="bg-orange-600 text-white text-[10px] px-2 py-1 rounded font-bold uppercase tracking-tighter">New</span>
                            </div>
                            <p class="text-gray-500 dark:text-gray-400 text-sm line-clamp-2 mt-2">รสสัมผัสที่เป็นเอกลักษณ์เฉพาะตัว ผสมผสานเครื่องเทศนำเข้าจากญี่ปุ่น</p>
                        </div>
                        <div class="mt-6 flex items-center justify-between">
                            <div>
                                <span class="text-xs text-gray-400 block uppercase font-bold">Price</span>
                                <span class="text-2xl font-black text-orange-600">฿<%= item.price %></span>
                            </div>
                            <button onclick="addToCart('<%= item._id %>')" class="h-12 w-12 rounded-2xl bg-gray-900 dark:bg-white text-white dark:text-black flex items-center justify-center transition-all hover:bg-orange-600 shadow-lg">
                                <i data-lucide="plus"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </section>

    <%- include('footer.ejs') %>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        lucide.createIcons();
        AOS.init({ duration: 1000, once: false });
    
    function toggleTheme() {
            const htmlElement = document.documentElement;
            if (htmlElement.classList.contains('dark')) {
                htmlElement.classList.remove('dark');
                console.log("Switched to Light Mode");
            } else {
                htmlElement.classList.add('dark');
                console.log("Switched to Dark Mode");
            }
    }


    let currentPromoIndex = 0;
    const promoItems = document.querySelectorAll('.promo-item');

    function rotatePromotions() {
        if (promoItems.length <= 1) return;
        promoItems[currentPromoIndex].classList.add('hidden');
        currentPromoIndex = (currentPromoIndex + 1) % promoItems.length;
        promoItems[currentPromoIndex].classList.remove('hidden');
    }

    if (promoItems.length > 1) {
        setInterval(rotatePromotions, 10000);
    }

    async function addToCart(productId = null, promoId = null) {
        try {
            const res = await axios.post('/cart/add', { 
                productId: productId, 
                promoId: promoId, 
                quantity: 1 
            });

            if (res.data.success) {
                showToast(res.data.message, true);
                
                const badge = document.getElementById('cart-count-badge');
                if (badge) {
                    badge.innerText = res.data.newCount;
                    badge.classList.remove('hidden');
                }
            } else if (res.data.message === "Please sign in to order!") {
                window.location.href = '/signin';
            }
        } catch (error) {
            console.error(error);
            showToast("Something went wrong. Please try again.", false);
        }
    }

    function showToast(message, isSuccess) {
        let container = document.getElementById('toast-container');
        if (!container) {
            container = document.createElement('div');
            container.id = 'toast-container';
            container.className = 'fixed bottom-5 right-5 z-[100] flex flex-col gap-2';
            document.body.appendChild(container);
        }

        const toast = document.createElement('div');
        toast.className = `flex items-center gap-3 px-5 py-3.5 rounded-2xl shadow-xl text-white transform transition-all duration-300 translate-y-10 opacity-0 ${isSuccess ? 'bg-green-600' : 'bg-red-600'}`;
        toast.innerHTML = `
            <i data-lucide="${isSuccess ? 'check-circle' : 'alert-circle'}" class="w-5 h-5"></i>
            <span class="text-sm font-medium">${message}</span>
        `;
        
        container.appendChild(toast);
        lucide.createIcons();

        setTimeout(() => toast.classList.remove('translate-y-10', 'opacity-0'), 10);
        setTimeout(() => {
            toast.classList.add('translate-y-10', 'opacity-0');
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }
    </script>
</body>
</html>