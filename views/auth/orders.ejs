<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head.ejs') %>
</head>
<body class="bg-gray-50 dark:bg-zinc-950 text-gray-900 dark:text-gray-100 transition-colors duration-300 min-h-screen">
    <main class="max-w-4xl mx-auto px-4 py-8">
        <div class="mb-6">
            <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                Back
            </button>
        </div>

        <div class="flex items-center gap-3 mb-8 border-b border-amber-500/10 dark:border-amber-500/5 pb-4">
            <div class="p-2 bg-amber-100 dark:bg-amber-950/20 rounded-xl border border-amber-200 dark:border-amber-900/40">
                <i data-lucide="history" class="w-6 h-6 text-amber-600 dark:text-amber-500 stroke-[1.5]"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-amber-600 dark:text-amber-500 tracking-tight">Order History</h1>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-0.5">Track your ramen journey</p>
            </div>
        </div>
        
        <% if (orders && orders.length > 0) { %>
            <div class="space-y-3">
                <% orders.forEach(order => { %>
                    <% 
                        const statusLower = order.status ? order.status.toLowerCase() : '';
                        const createdAtTime = new Date(order.createdAt).getTime();
                    %>
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-sm border border-gray-200 dark:border-zinc-800 overflow-hidden">
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-4 sm:p-5 cursor-pointer hover:bg-gray-50 dark:hover:bg-zinc-800/50 transition-colors gap-3" onclick="toggleOrder('<%= order._id %>')">
                            <div class="space-y-1 flex-1">
                                <div class="flex items-center gap-2">
                                    <i data-lucide="receipt" class="w-3.5 h-3.5 text-amber-500"></i>
                                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400">
                                        Order ID: <span class="text-gray-800 dark:text-gray-200 font-bold">#<%= order._id.toString().substring(0,8).toUpperCase() %></span>
                                    </p>
                                </div>
                                <div class="flex items-center gap-2">
                                    <i data-lucide="calendar" class="w-3.5 h-3.5 text-gray-400"></i>
                                    <p class="text-xs text-gray-600 dark:text-gray-400">
                                        <%= new Date(order.createdAt).toLocaleString() %>
                                    </p>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between sm:justify-end w-full sm:w-auto gap-4">
                                <span id="status-badge-<%= order._id %>" class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold tracking-wide border
                                    <%= statusLower === 'completed' ? 'bg-emerald-100 text-emerald-700 border-emerald-200 dark:bg-emerald-950/30 dark:text-emerald-400' : 
                                        statusLower === 'cancelled' ? 'bg-red-100 text-red-700 border-red-200 dark:bg-red-950/30 dark:text-red-400' :
                                        'bg-sky-100 text-sky-700 border-sky-200 dark:bg-sky-950/30 dark:text-sky-400' %>">
                                    <%= order.status %>
                                </span>
                                
                                <div class="flex items-center gap-3">
                                    <span class="text-base font-bold text-orange-600">฿<%= (order.totalAmount || 0).toLocaleString() %></span>
                                    <div class="p-1 bg-gray-100 dark:bg-zinc-800 rounded-full transition-transform duration-300" id="icon-<%= order._id %>">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div id="content-<%= order._id %>" class="hidden border-t border-gray-100 dark:border-zinc-800 bg-gray-50/50 dark:bg-zinc-950/50 p-4 sm:p-5">
                            <ul class="space-y-3">
                                <% order.items.forEach(item => { %>
                                    <li class="flex justify-between items-center bg-white dark:bg-zinc-900 p-3 rounded-xl border border-gray-100 dark:border-zinc-800 shadow-sm">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-amber-50 dark:bg-zinc-800 rounded-lg flex items-center justify-center border border-amber-100 dark:border-zinc-700">
                                                <i data-lucide="soup" class="w-5 h-5 text-amber-600"></i>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= item.menuName %></p>
                                                <p class="text-xs text-gray-500">Qty: <%= item.quantity %></p>
                                            </div>
                                        </div>
                                        <span class="font-semibold text-sm">฿<%= (item.price * item.quantity).toLocaleString() %></span>
                                    </li>
                                <% }) %>
                            </ul>
                            
                            <div class="mt-4 pt-4 border-t border-gray-200 dark:border-zinc-700/80 flex justify-between items-center">
                                <span class="font-bold text-gray-800 dark:text-gray-300 text-sm">Total Amount</span>
                                <div class="flex items-center gap-4">
                                    <% if (statusLower === 'preparing') { %>
                                        <div id="cancel-container-<%= order._id %>" data-created="<%= createdAtTime %>" class="cancel-timer-btn">
                                            <button onclick="handleCancel('<%= order._id %>')" class="text-xs font-bold text-red-500 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg border border-red-200 transition-all">
                                                Cancel Order
                                            </button>
                                        </div>
                                    <% } %>
                                    <span class="text-lg font-bold text-orange-600">฿<%= (order.totalAmount || 0).toLocaleString() %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        lucide.createIcons();
        
        function toggleOrder(id) {
            document.getElementById('content-' + id).classList.toggle('hidden');
            document.getElementById('icon-' + id).classList.toggle('rotate-180');
        }

        function updateCancelButtons() {
            const now = new Date().getTime();
            document.querySelectorAll('.cancel-timer-btn').forEach(container => {
                const createdAt = parseInt(container.getAttribute('data-created'));
                if (now - createdAt > 120000) {
                    container.remove();
                }
            });
        }

        setInterval(updateCancelButtons, 1000);
        updateCancelButtons();

        async function handleCancel(id) {
            const result = await Swal.fire({
                title: 'Confirm Cancellation?',
                text: "Order will be cancelled immediately.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                confirmButtonText: 'Yes, cancel it!',
                background: document.documentElement.classList.contains('dark') ? '#18181b' : '#fff',
                color: document.documentElement.classList.contains('dark') ? '#fff' : '#000'
            });

            if (result.isConfirmed) {
                try {
                    const res = await fetch(`/orders/cancel/${id}`, { method: 'POST' });
                    if (res.ok) {
                        const badge = document.getElementById('status-badge-' + id);
                        badge.innerText = 'cancelled';
                        badge.className = 'inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold tracking-wide border bg-red-100 text-red-700 border-red-200 dark:bg-red-950/30 dark:text-red-400';
                        const btnContainer = document.getElementById('cancel-container-' + id);
                        if(btnContainer) btnContainer.remove();
                        Swal.fire('Cancelled!', 'Your order has been cancelled.', 'success');
                    } else {
                        const err = await res.json();
                        Swal.fire('Error', err.message, 'error');
                    }
                } catch (e) {
                    Swal.fire('Error', 'Network error', 'error');
                }
            }
        }
    </script>
</body>
</html>