<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head.ejs') %>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body class="bg-gray-50 dark:bg-zinc-950 text-gray-900 dark:text-gray-100 transition-colors duration-300 min-h-screen">
    
    <main class="max-w-4xl mx-auto px-4 py-8">
        
        <div class="mb-6">
            <a href="javascript:history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                Back
            </a>
        </div>

        <div class="flex items-center gap-3 mb-8 border-b border-amber-500/10 dark:border-amber-500/5 pb-4">
            <div class="p-2 bg-amber-100 dark:bg-amber-950/20 rounded-xl border border-amber-200 dark:border-amber-900/40">
                <i data-lucide="history" class="w-6 h-6 text-amber-600 dark:text-amber-500 stroke-[1.5]"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-amber-600 dark:text-amber-500 tracking-tight">Order History</h1>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-0.5">Click on an order to view details</p>
            </div>
        </div>
        
        <% if (orders && orders.length > 0) { %>
            <div class="space-y-3">
                <% orders.forEach(order => { %>
                    <% 
                        const calculatedTotal = order.items.reduce((sum, item) => sum + ((item.price || 0) * (item.quantity || 1)), 0);
                        const displayTotal = order.totalPrice || calculatedTotal;
                    %>
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-sm border border-gray-200 dark:border-zinc-800 transition-all hover:shadow-md overflow-hidden">
                        
                        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-4 sm:p-5 cursor-pointer hover:bg-gray-50 dark:hover:bg-zinc-800/50 transition-colors gap-3" onclick="toggleOrder('<%= order._id %>')">
                            <div class="space-y-1 w-full sm:w-auto flex-1">
                                <div class="flex items-center gap-2">
                                    <i data-lucide="receipt" class="w-3.5 h-3.5 text-amber-500"></i>
                                    <p class="text-xs font-medium text-gray-500 dark:text-gray-400">
                                        Order ID: <span class="text-gray-800 dark:text-gray-200 font-bold"><%= order._id %></span>
                                    </p>
                                </div>
                                <div class="flex items-center gap-2">
                                    <i data-lucide="calendar" class="w-3.5 h-3.5 text-gray-400"></i>
                                    <p class="text-xs text-gray-600 dark:text-gray-400">
                                        <% 
                                            const options = { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute:'2-digit' };
                                            const formattedDate = new Date(order.createdAt).toLocaleDateString('en-US', options);
                                        %>
                                        <%= formattedDate %>
                                    </p>
                                </div>
                            </div>
                            
                            <div class="flex items-center justify-between sm:justify-end w-full sm:w-auto gap-4 mt-2 sm:mt-0">
                                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold tracking-wide border
                                    <%= order.status === 'Completed' || order.status === 'เสร็จสิ้น' ? 'bg-amber-100 text-amber-700 dark:bg-amber-950/30 dark:text-amber-400 border-amber-200 dark:border-amber-900/50' : 'bg-orange-100 text-orange-700 dark:bg-orange-950/30 dark:text-orange-400 border-orange-200 dark:border-orange-900/50' %>">
                                    <% if (order.status === 'Completed' || order.status === 'เสร็จสิ้น') { %>
                                        <i data-lucide="check-circle-2" class="w-3 h-3"></i>
                                        Completed
                                    <% } else { %>
                                        <i data-lucide="clock" class="w-3 h-3"></i>
                                        <%= order.status %>
                                    <% } %>
                                </span>
                                
                                <div class="flex items-center gap-3">
                                    <span class="text-base font-bold text-orange-600 dark:text-orange-500">฿<%= displayTotal %></span>
                                    <div class="p-1 bg-gray-100 dark:bg-zinc-800 rounded-full text-gray-500 dark:text-gray-400 transition-transform duration-300" id="icon-<%= order._id %>">
                                        <i data-lucide="chevron-down" class="w-4 h-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div id="content-<%= order._id %>" class="hidden border-t border-gray-100 dark:border-zinc-800 bg-gray-50/50 dark:bg-zinc-950/50 p-4 sm:p-5">
                            <ul class="space-y-3">
                                <% order.items.forEach(item => { %>
                                    <li class="flex justify-between items-center gap-3 bg-white dark:bg-zinc-900 p-3 rounded-xl border border-gray-100 dark:border-zinc-800 shadow-sm">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 bg-amber-50 dark:bg-zinc-800 rounded-lg flex items-center justify-center border border-amber-100 dark:border-zinc-700 flex-shrink-0">
                                                <i data-lucide="soup" class="w-5 h-5 text-amber-600 dark:text-amber-500 stroke-[1.5]"></i>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= item.menuName || 'Unknown Item' %></p>
                                                <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">Quantity: <span class="font-medium"><%= item.quantity %></span> bowl(s)</p>
                                            </div>
                                        </div>
                                        <span class="font-semibold text-gray-800 dark:text-gray-200 text-sm">฿<%= (item.price || 0) * (item.quantity || 1) %></span>
                                    </li>
                                <% }) %>
                            </ul>
                            
                            <div class="mt-4 pt-4 border-t border-gray-200 dark:border-zinc-700/80 flex justify-between items-center">
                                <span class="font-bold text-gray-800 dark:text-gray-300 text-sm">Order Total</span>
                                <span class="text-lg font-bold text-orange-600 dark:text-orange-500">฿<%= displayTotal %></span>
                            </div>
                        </div>
                        
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="text-center py-16 bg-white dark:bg-zinc-900 rounded-2xl border border-gray-200 dark:border-zinc-800 shadow-sm flex flex-col items-center p-8">
                <i data-lucide="utensils-crossed" class="w-16 h-16 text-gray-300 dark:text-zinc-700 mb-4 stroke-[1]"></i>
                <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2 tracking-tight">No order history yet</h2>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-6 max-w-sm">You haven't ordered any ramen with us yet. Check out our recommended menu and order your first bowl!</p>
                <a href="/menu" class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 dark:bg-amber-600 dark:hover:bg-amber-700 text-white font-bold px-6 py-2.5 rounded-full transition-all duration-300 shadow-sm hover:shadow-md text-sm">
                    <i data-lucide="shopping-bag" class="w-4 h-4"></i>
                    View Menu
                </a>
            </div>
        <% } %>
    </main>

    <script>
        lucide.createIcons();

        function toggleOrder(orderId) {
            const content = document.getElementById('content-' + orderId);
            const icon = document.getElementById('icon-' + orderId);
            
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                icon.classList.add('rotate-180');
            } else {
                content.classList.add('hidden');
                icon.classList.remove('rotate-180');
            }
        }
    </script>
</body>
</html>