<script src="https://unpkg.com/lucide@latest"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<nav
    class="fixed top-0 left-0 w-full z-[100] transition-all duration-300 shadow-lg p-4 bg-orange-500/20 backdrop-blur-md dark:bg-neutral-950/80 border-b border-white/10">
    <div class="container mx-auto flex justify-between items-center">

        <a href="#" class="flex items-center gap-2 group">
            <div
                class="h-10 w-10 bg-[url(/images/icon/ramen_w.png)] bg-cover transition-transform group-hover:rotate-12 dark:bg-[url(/images/icon/ramen_d.png)]">
            </div>
            <span class="text-white font-bold text-xl tracking-tighter hidden md:block">KAIZEN</span>
        </a>

        <div class="flex items-center gap-1 md:gap-4">
            <ul class="hidden lg:flex items-center text-white font-medium">
                <li><a href="/" class="px-4 py-2 rounded-full hover:bg-white/20 transition duration-300">Home</a></li>
                <li><a href="/menu" class="px-4 py-2 rounded-full hover:bg-white/20 transition duration-300">Menu</a>
                </li>
                <li><a href="/about" class="px-4 py-2 rounded-full hover:bg-white/20 transition duration-300">About</a>
                </li>
                <li><a href="/contact"
                        class="px-4 py-2 rounded-full hover:bg-white/20 transition duration-300">Contact</a>
                </li>
            </ul>

            <div class="h-8 w-[1px] bg-white/20 mx-2 hidden lg:block"></div>

            <div class="flex items-center gap-3">
                <button onclick="toggleTheme()"
                    class="p-2 text-white hover:bg-white/20 rounded-full transition duration-300">
                    <i data-lucide="sun" class="w-5 h-5 dark:hidden"></i>
                    <i data-lucide="moon" class="w-5 h-5 hidden dark:block"></i>
                </button>

                <% if (user) { %>
                    <div class="relative" x-data="{ open: false }">
                        <button @click.stop="open = !open"
                            class="flex items-center gap-3 p-1 pr-3 bg-white/10 hover:bg-white/20 rounded-full transition-all duration-300 border border-white/10">
                            <img src="/images/profile/<%= user.image %>"
                                class="w-8 h-8 rounded-full object-cover border-2 border-orange-500">
                            <span class="text-white text-sm font-medium hidden sm:block">
                                <%= user.name %>
                            </span>
                            <i class="fas fa-chevron-down text-white text-[10px] transition-transform"
                                :class="open ? 'rotate-180' : ''"></i>
                        </button>

                        <div x-show="open" @click.away="open = false"
                            x-transition:enter="transition ease-out duration-100"
                            x-transition:enter-start="transform opacity-0 scale-95"
                            x-transition:enter-end="transform opacity-100 scale-100"
                            x-transition:leave="transition ease-in duration-75"
                            x-transition:leave-start="transform opacity-100 scale-100"
                            x-transition:leave-end="transform opacity-0 scale-95"
                            class="absolute right-0 mt-3 w-56 origin-top-right rounded-2xl bg-white dark:bg-neutral-900 shadow-2xl ring-1 ring-black ring-opacity-5 z-[110] overflow-hidden"
                            style="display: none;">

                            <div class="px-4 py-3 bg-orange-500/10 border-b border-gray-100 dark:border-white/5">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Signed in as</p>
                                <p class="text-sm font-bold text-orange-600 dark:text-orange-400 truncate">
                                    <%= user.email %>
                                </p>
                            </div>

                            <div class="py-1">
                                <a href="/profile"
                                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-orange-50 dark:hover:bg-white/5 transition">
                                    <i class="fas fa-user-circle text-orange-500 w-5"></i> My Profile
                                </a>
                                <a href="/orders"
                                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-orange-50 dark:hover:bg-white/5 transition">
                                    <i class="fas fa-shopping-bag text-orange-500 w-5"></i> My Orders
                                </a>
                                <a href="/settings"
                                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 dark:text-gray-200 hover:bg-orange-50 dark:hover:bg-white/5 transition">
                                    <i class="fas fa-cog text-orange-500 w-5"></i> Settings
                                </a>
                            </div>

                            <div class="border-t border-gray-100 dark:border-white/5 py-1">
                                <a href="/logout"
                                    class="flex items-center gap-3 px-4 py-2.5 text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition font-bold">
                                    <i class="fas fa-sign-out-alt w-5"></i> Sign Out
                                </a>
                            </div>
                        </div>
                    </div>

                    <% } else { %>
                        <a href="/register"
                            class="flex items-center gap-2 px-6 py-2 bg-orange-600 hover:bg-orange-500 text-white rounded-full font-bold shadow-lg transition-all duration-300 active:scale-95">
                            <span class="text-sm">Register</span>
                        </a>

                        <a href="/signin"
                            class="flex items-center gap-2 px-6 py-2 border-2 border-orange-600 text-orange-600 hover:bg-orange-50 rounded-full font-bold transition-all duration-300 active:scale-95">
                            <span class="text-sm">Sign In</span>
                        </a>
                        <% } %>
            </div>
        </div>
    </div>
</nav>

<script>
    tailwind.config = {
        darkMode: 'class',
        theme: {
            extend: {
                colors: {
                    clifford: '#ada397',
                }
            }
        }
    }
</script>
<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>