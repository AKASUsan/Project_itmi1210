<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../../head.ejs') %>
</head>
<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 transition-colors duration-300 min-h-screen font-sans">
    <div class="flex flex-col min-h-screen">
        <main class="p-4 md:p-10 flex-grow">
            <div class="max-w-3xl mx-auto">
                <div class="mb-8 flex items-center gap-4">
                     <div class="mb-6">
            <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                Back
            </button>
        </div>

                    <h1 class="text-3xl font-black tracking-wide text-zinc-900 dark:text-zinc-100 uppercase">
                        Edit <span class="text-kaizen-orange">Menu</span>
                    </h1>
                </div>

                <div class="bg-white dark:bg-kaizen-dark border border-kaizen-tan dark:border-zinc-800 rounded-2xl shadow-sm p-6 md:p-8">
                    <form action="/menus/edit/<%= menu._id %>" method="POST" enctype="multipart/form-data" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Menu Name</label>
                                <input type="text" name="name" value="<%= menu.name %>" required class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange transition-colors">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Price (฿)</label>
                                <input type="number" name="price" value="<%= menu.price %>" required class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange transition-colors">
                            </div>
                            <div>
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Category</label>
                                <select name="category" class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange transition-colors font-bold text-zinc-700 dark:text-zinc-300">
                                    <option value="Ramen" <%= menu.category === 'Ramen' ? 'selected' : '' %>>Ramen</option>
                                    <option value="Appetizer" <%= menu.category === 'Appetizer' ? 'selected' : '' %>>Appetizer</option>
                                    <option value="Beverage" <%= menu.category === 'Beverage' ? 'selected' : '' %>>Beverage</option>
                                    <option value="Dessert" <%= menu.category === 'Dessert' ? 'selected' : '' %>>Dessert</option>
                                </select>
                            </div>
                            
                            <div class="flex flex-col items-start">
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Menu Image</label>
                                <div class="flex items-center gap-4">
                                    <div class="relative w-20 h-20 rounded-xl overflow-hidden border-2 border-dashed border-kaizen-tan dark:border-zinc-700 flex items-center justify-center bg-[#faf8f5] dark:bg-zinc-900">
                                        <img id="image_preview" src="/images/product/<%= menu.image %>" alt="Preview" class="w-full h-full object-cover <%= !menu.image ? 'hidden' : '' %>">
                                        <i data-lucide="image" id="no_image_icon" class="w-8 h-8 text-zinc-400 <%= menu.image ? 'hidden' : '' %>"></i>
                                    </div>
                                    <div class="flex flex-col gap-2">
                                        <input type="file" name="image" id="image_upload" accept="image/*" class="hidden">
                                        <button type="button" id="upload_button" class="bg-white dark:bg-zinc-800 border border-kaizen-tan dark:border-zinc-700 hover:bg-zinc-50 dark:hover:bg-zinc-700 text-zinc-700 dark:text-zinc-300 font-bold py-2 px-4 rounded-xl transition-colors text-sm flex items-center gap-2">
                                            <i data-lucide="upload" class="w-4 h-4"></i> Change Image
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="md:col-span-2">
                                <label class="block text-sm font-bold text-zinc-700 dark:text-zinc-300 mb-2">Description</label>
                                <textarea name="description" rows="3" class="w-full px-4 py-3 rounded-xl bg-[#faf8f5] dark:bg-zinc-900 border border-kaizen-tan dark:border-zinc-700 focus:outline-none focus:border-kaizen-orange transition-colors"><%= menu.description %></textarea>
                            </div>
                        </div>

                        <div class="flex items-center gap-3 pt-2">
                            <input type="checkbox" name="isAvailable" id="isAvailable" <%= menu.isAvailable ? 'checked' : '' %> class="w-5 h-5 accent-kaizen-orange rounded">
                            <label for="isAvailable" class="text-sm font-bold text-zinc-700 dark:text-zinc-300 cursor-pointer">Available for Order</label>
                        </div>

                        <div class="pt-6 border-t border-kaizen-tan dark:border-zinc-800 flex justify-end gap-4">
                            <a href="/menus" class="px-6 py-3 rounded-xl font-bold text-zinc-500 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors">Cancel</a>
                            <button type="submit" class="bg-kaizen-orange hover:bg-orange-600 text-white font-bold py-3 px-8 rounded-xl shadow-md transition-all active:scale-95 uppercase tracking-wide text-sm flex items-center gap-2">
                                <i data-lucide="refresh-cw" class="w-4 h-4"></i> Update Menu
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
    <script>
        lucide.createIcons();
        
         if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
        }

        const uploadButton = document.getElementById('upload_button');
        const fileInput = document.getElementById('image_upload');
        const preview = document.getElementById('image_preview');
        const noImageIcon = document.getElementById('no_image_icon');

        uploadButton.addEventListener('click', () => fileInput.click());

        fileInput.addEventListener('change', function(event) {
            const input = event.target;
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.classList.remove('hidden');
                    noImageIcon.classList.add('hidden');
                }
                reader.readAsDataURL(input.files[0]);
            }
        });
    </script>
</body>
</html>