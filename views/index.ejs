<!--
TODO:ออกแบบหน้าเว็บใหม่จัดการเรื่องอนิเมชั่นให้โค้ดสระอาด
    ทำเรื่องอนิเมชั่นกับปุ่ม สินค้า 
-->
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="./output.css" rel="stylesheet">
</head>

<body>
    <%- include('navbar.ejs') %>
        <div
            class="relative bg-[url('/images/background/Ramem4.jpg')] bg-cover bg-center h-[500px] w-full flex items-center justify-center">
            <div class="absolute inset-0 bg-black/40"></div>
            <div class="relative z-10 w-max">
                <div class="flex min-h-screen items-center justify-center p-10">
                    <div class="w-max">
                        <h1
                            class="animate-typing overflow-hidden whitespace-nowrap border-r-4 border-r-white pr-5 leading-tight pb-2 text-5xl text-white font-bold">
                            รสชาติแห่งความอบอุ่น... ที่ส่งตรงจากเตาถึงชามคุณ
                        </h1>
                    </div>
                </div>
            </div>
        </div>

        <div class="max-w-[80rem] mx-auto mt-10 grid grid-cols-1 md:grid-cols-2 gap-10 items-center">

            <div class="reveal-on-scroll opacity-0 flex flex-col justify-center px-10 lg:px-20">
                <h1
                    class="text-5xl font-bold mb-8 underline decoration-amber-200 underline-offset-8 text-center md:text-left">
                    Ramen Tonkotsu
                </h1>
                <p class="text-xl leading-loose text-gray-800 text-justify md:text-left">
                    ราเมงของเราไม่ใช่แค่บะหมี่น้ำ แต่คือผลึกของเวลาและความพยายาม เราเริ่มต้นจาก น้ำซุป
                    ที่เคี่ยวกรำนานหลายสิบชั่วโมงจนได้ความเข้มข้นระดับโมเลกุล ผสมผสานกับเส้นสด
                    ที่เรานวดเองมือต่อมือ เพื่อให้ได้ความเหนียวนุ่มที่รับกับน้ำซุปได้อย่างสมบูรณ์แบบ
                    ท็อปด้วยหมูชาชูที่นุ่มจนแทบละลายในปาก... นี่คือรสชาติแบบดั้งเดิมที่เราอยากให้คุณสัมผัส
                </p>
            </div>

            <div class="reveal-on-scroll opacity-0 [animation-delay:200ms] w-full flex justify-center md:justify-end">
                <div
                    class="bg-[url('/images/background/kouji-tsuru.jpg')] bg-cover bg-center h-[600px] w-full max-w-[600px] shadow-2xl shadow-black/40 rounded-4xl">
                </div>
            </div>
        </div>

        <div class="container mx-auto px-4">

            <% Object.values(products).forEach(function(item){ %>
            <div class="row mx-auto">
                    <div class="card pt-20">
                        <div class="grid h-56 grid-cols-4 content-start gap-4">
                            <div>
                                <img src="<%= item.image %>" alt="<%= item.image %>">
                                <h1>
                                    <%= item.name %>
                                </h1>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>
        </div>
        <script src="https://cdn.tailwindcss.com"></script>
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        keyframes: {
                            typing: {
                                "0%": {
                                    width: "0%",
                                    visibility: "hidden"
                                },
                                "100%": {
                                    width: "100%"
                                }
                            },
                            blink: {
                                "50%": {
                                    borderColor: "transparent"
                                },
                                "100%": {
                                    borderColor: "white"
                                }
                            }
                        },
                        animation: {
                            typing: "typing 6.5s steps(50)  alternate, blink 0.5s infinite"
                        }
                    },
                },
                plugins: [],
            }
            tailwind.config = {
                safelist: ['animate-fade-up'],
                theme: {
                    extend: {
                        keyframes: {
                            fadeUp: {
                                '0%': { opacity: '0', transform: 'translateY(50px)' },
                                '100%': { opacity: '1', transform: 'translateY(0)' },
                            }
                        },
                        animation: {
                            'fade-up': 'fadeUp 0.8s ease-out forwards',
                        }
                    }
                }
            }
        </script>


        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const observer = new IntersectionObserver((entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("animate-fade-up");
                            observer.unobserve(entry.target);
                        }
                    });
                }, {
                    threshold: 0.15
                });

                const hiddenElements = document.querySelectorAll(".reveal-on-scroll");
                hiddenElements.forEach((el) => observer.observe(el));
            });
        </script>
</body>

</html>