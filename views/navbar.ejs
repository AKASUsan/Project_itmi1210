<nav class="fixed top-4 left-330 -translate-x-1/2 z-50 w-full max-w-4xl px-4  ">
    <div class="bg-white/80 backdrop-blur-md p-4 rounded-4xl shadow-xl shadow-indigo-100 flex items-center justify-between px-10 pr-30 ">
        
        <div class="flex items-center gap-10">
            <a href="/" class="text-black text-xl font-bold">POS</a>
            <ul class="navbar-nav flex gap-4">
                <li>
                    <a href="/" class="transition duration-300 ease-in-out hover:-translate-y-1 hover:scale-110 px-5 py-2 rounded-xl hover:bg-zinc-300 block">Home</a>
                </li>
                <li>
                    <a href="/" class="transition duration-300 ease-in-out hover:-translate-y-1 hover:scale-110 px-5 py-2 rounded-xl hover:bg-zinc-300 block">Menu</a>
                </li>
            </ul>
        </div>
        <div class="flex items-center gap-4">
            <ul class="flex gap-2">
                <li>
                    <a href="/login" class="transition duration-300 px-6 py-2 rounded-xl bg-rose-900 text-white hover:bg-purple-300 block text-sm">Login</a>
                </li>
                <li>
                    <a href="/register" class="transition duration-300 px-6 py-2 rounded-xl bg-rose-600 text-white hover:bg-purple-400 block text-sm">Register</a>
                </li>
            </ul>

            <div class="relative inline-block text-left">
                <button id="options-menu-button" type="button" class="p-2 rounded-full hover:bg-gray-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                </button>

                <div id="options-menu" class="absolute right-0 z-10 mt-2 w-56 origin-top-right divide-y divide-gray-600 rounded-md bg-gray-800 shadow-lg ring-1 ring-black/5 focus:outline-none transition-all duration-200 opacity-0 scale-95 pointer-events-none">
                    <div class="py-1">
                        <a href="#" class="flex items-center gap-x-2 px-4 py-2 text-sm text-gray-300 hover:bg-gray-700">Edit</a>
                        <a href="#" class="flex items-center gap-x-2 px-4 py-2 text-sm text-gray-300 hover:bg-gray-700">Duplicate</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>
<script>
    const button = document.getElementById('options-menu-button');
    const menu = document.getElementById('options-menu');

    // ฟังก์ชันสำหรับเปิด-ปิดเมนู โดยสลับคลาสแอนิเมชัน
    const toggleMenu = () => {
        menu.classList.toggle('opacity-0');
        menu.classList.toggle('scale-95');
        menu.classList.toggle('pointer-events-none');
    };

    button.addEventListener('click', toggleMenu);

    window.addEventListener('click', (event) => {
        // ถ้าคลิกข้างนอก และเมนูเปิดอยู่ (ดูจากว่าไม่มีคลาส opacity-0) ให้ปิดเมนู
        if (!button.contains(event.target) && !menu.contains(event.target) && !menu.classList.contains('opacity-0')) {
            toggleMenu();
        }
    });
    document.addEventListener('DOMContentLoaded', function () {
        // สมมติว่าคุณเก็บสถานะล็อกอินไว้ใน variable หรือ localStorage
        const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
        const menuButton = document.querySelector('.relative.inline-block');

        if (!isLoggedIn) {
            menuButton.style.display = 'none'; // ซ่อนถ้ายังไม่ล็อกอิน
        }
    });
</script>