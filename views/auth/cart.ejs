<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../head.ejs') %>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</head>
<body class="bg-gray-50 dark:bg-zinc-950 text-gray-900 dark:text-gray-100 transition-colors duration-300 min-h-screen">
    
    <main class="max-w-4xl mx-auto px-4 py-8">
        
        <div class="mb-6">
            <a href="/menu" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                Back
            </a>
        </div>

        <div class="flex items-center gap-3 mb-8 border-b border-amber-500/10 dark:border-amber-500/5 pb-4">
            <div class="p-2 bg-amber-100 dark:bg-amber-950/20 rounded-xl border border-amber-200 dark:border-amber-900/40">
                <i data-lucide="shopping-cart" class="w-6 h-6 text-amber-600 dark:text-amber-500 stroke-[1.5]"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-amber-600 dark:text-amber-500 tracking-tight">Your Cart</h1>
                <p class="text-xs text-gray-600 dark:text-gray-400 mt-0.5">Review your items before checkout</p>
            </div>
        </div>

        <% 
            let totalItems = 0;
            let totalPrice = 0; 
        %>

        <% if (cartItems && cartItems.length > 0) { %> 
            <div class="flex flex-col md:flex-row gap-6">
                
                <div class="flex-1 space-y-3">
                    <% cartItems.forEach(item => { %>
                        <% 
                            totalItems += item.quantity;
                            totalPrice += (item.price * item.quantity);
                        %>
                        <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-sm border border-gray-200 dark:border-zinc-800 transition-all hover:shadow-md overflow-hidden" id="item-<%= item._id %>">
                            
                            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center p-4 sm:p-5 gap-3">
                                
                                <div class="flex items-center gap-3 w-full sm:w-auto flex-1">
                                    <div class="w-10 h-10 bg-amber-50 dark:bg-zinc-800 rounded-lg flex items-center justify-center border border-amber-100 dark:border-zinc-700 flex-shrink-0">
                                        <i data-lucide="soup" class="w-5 h-5 text-amber-600 dark:text-amber-500 stroke-[1.5]"></i>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= item.name %></p>
                                        <p class="text-xs font-bold text-orange-600 dark:text-orange-500 mt-0.5">฿<%= item.price %></p>
                                    </div>
                                </div>

                                <div class="flex items-center justify-between sm:justify-end w-full sm:w-auto gap-4 mt-2 sm:mt-0">
                                    
                                    <div class="flex items-center justify-between w-28 border border-gray-200 dark:border-zinc-700 rounded-full bg-gray-50 dark:bg-zinc-950/50 p-1">
                                        <button onclick="updateQuantity('<%= item._id %>', 'decrease')" 
                                                class="w-8 h-8 flex items-center justify-center rounded-full text-gray-500 hover:bg-white dark:text-gray-400 dark:hover:bg-zinc-800 transition-all shrink-0">
                                            <i data-lucide="minus" class="w-3 h-3"></i>
                                        </button>

                                        <span class="flex-1 text-center text-sm font-bold text-gray-900 dark:text-white">
                                            <%= item.quantity %>
                                        </span>

                                        <button onclick="updateQuantity('<%= item._id %>', 'increase')" 
                                                class="w-8 h-8 flex items-center justify-center rounded-full text-gray-500 hover:bg-white dark:text-gray-400 dark:hover:bg-zinc-800 transition-all shrink-0">
                                            <i data-lucide="plus" class="w-3 h-3"></i>
                                        </button>
                                    </div>
                                    
                                    <div class="flex items-center gap-3">
                                        <span class="text-base font-bold text-orange-600 dark:text-orange-500 w-16 text-right">฿<%= item.price * item.quantity %></span>
                                        <button onclick="removeItem('<%= item._id %>')" class="p-1.5 text-gray-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 rounded-lg transition-all">
                                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                                        </button>
                                    </div>

                                </div>
                            </div>
                        </div>
                    <% }) %> </div>

                <div class="w-full md:w-72 lg:w-80">
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl shadow-sm border border-gray-200 dark:border-zinc-800 p-5 sticky top-8">
                        <h2 class="text-sm font-bold text-gray-800 dark:text-gray-200 mb-4 border-b border-gray-100 dark:border-zinc-800 pb-3">Order Summary</h2>
                        
                        <div class="space-y-3 mb-5">
                            <div class="flex justify-between text-xs">
                                <span class="text-gray-500 dark:text-gray-400">Total Items (<%= totalItems %>)</span>
                                <span class="font-medium text-gray-800 dark:text-gray-200">฿<%= totalPrice %></span>
                            </div>
                        </div>
                        
                        <div class="border-t border-gray-100 dark:border-zinc-800 pt-4 mb-5">
                            <div class="flex justify-between items-end">
                                <span class="text-sm font-bold text-gray-800 dark:text-gray-200">Total</span>
                                <span class="text-lg font-bold text-orange-600 dark:text-orange-500">฿<%= totalPrice %></span>
                            </div>
                        </div>

                        <a href="/checkout" class="w-full flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 dark:bg-amber-600 dark:hover:bg-amber-700 text-white font-bold py-2.5 px-6 rounded-full transition-all duration-300 shadow-sm hover:shadow-md text-sm">
                            Checkout
                            <i data-lucide="arrow-right" class="w-4 h-4"></i>
                        </a>
                    </div>
                </div>

            </div>
        <% } else { %>
            <div class="text-center py-16 bg-white dark:bg-zinc-900 rounded-2xl border border-gray-200 dark:border-zinc-800 shadow-sm flex flex-col items-center p-8">
                <i data-lucide="shopping-cart" class="w-16 h-16 text-gray-300 dark:text-zinc-700 mb-4 stroke-[1]"></i>
                <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-2 tracking-tight">Your cart is empty</h2>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-6 max-w-sm">Looks like you haven't made your choice yet. Let's find some delicious ramen!</p>
                <a href="/menu" class="inline-flex items-center justify-center gap-2 bg-amber-500 hover:bg-amber-600 dark:bg-amber-600 dark:hover:bg-amber-700 text-white font-bold px-6 py-2.5 rounded-full transition-all duration-300 shadow-sm hover:shadow-md text-sm">
                    <i data-lucide="shopping-bag" class="w-4 h-4"></i>
                    Explore Menu
                </a>
            </div> 
        <% } %> </main>

    <script>
        lucide.createIcons();

        async function updateQuantity(productId, action) {
            try {
                const res = await axios.post('/cart/update', { productId, action });
                if (res.data.success) {
                    location.reload(); 
                }
            } catch (error) {
                console.error(error);
            }
        }

        async function removeItem(productId) {
            if(!confirm('Are you sure you want to remove this item?')) return;
            try {
                const res = await axios.post('/cart/remove', { productId });
                if(res.data.success) {
                    location.reload();
                }
            } catch (error) {
                console.error(error);
            }
        }
    </script>
    </body>
</html>