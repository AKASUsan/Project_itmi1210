<!DOCTYPE html>
<html lang="en">
้<head>
    <%- include('head.ejs') %>
</head>

<body class="bg-white text-gray-900 dark:bg-gray-900 dark:text-white">
    <%- include('navbar.ejs') %>

        <div class="relative h-screen w-full overflow-hidden flex items-center justify-center">

            <div
                class="absolute inset-0 bg-[url(/images/background/ramen-b.jpg)] bg-cover bg-center 
                    brightness-75 opacity-30 dark:opacity-100 dark:brightness-50 blur-[2px] scale-105 transition-all duration-700">
            </div>

            <div class="relative z-10 text-center px-6 max-w-5xl" data-aos="zoom-in" data-aos-duration="1000">
                <p
                    class="text-orange-600 dark:text-orange-400 text-lg md:text-xl tracking-[0.3em] uppercase mb-4 font-bold">
                    Crafting Perfection in Every Bowl
                </p>

                <h1 class="text-7xl md:text-9xl macondo-regular leading-none mb-2 drop-shadow-md">
                    Welcome To
                </h1>
                <h1 class="text-6xl md:text-8xl macondo-regular mb-10 tracking-tight drop-shadow-md">
                    KAIZEN RAMEN
                </h1>

                <p class="text-lg md:text-2xl mb-12 font-light max-w-3xl mx-auto leading-relaxed italic opacity-80">
                    "The art of continuous improvement, served in a bowl of 18-hour slow-cooked broth and artisanal
                    handmade noodles."
                </p>

                <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
                    <a href="/menu" data-aos="zoom-in" data-aos-delay="300"
                        class="group relative px-10 py-4 bg-red-600 hover:bg-red-700 text-white rounded-full transition-all duration-300 font-bold text-lg shadow-xl hover:scale-110 active:scale-95 overflow-hidden">
                        <span class="relative z-10">EXPLORE MENU</span>
                    </a>

                    <a href="#reservation" data-aos="zoom-in" data-aos-delay="500"
                        class="px-10 py-4 bg-transparent border-2 border-orange-600 dark:border-white hover:bg-orange-600 dark:hover:bg-white hover:text-white dark:hover:text-black rounded-full transition-all duration-300 font-bold text-lg backdrop-blur-sm">
                        BOOK A TABLE
                    </a>
                </div>
            </div>
        </div>
    <div class="relative flex flex-col items-center justify-center py-20 overflow-hidden">
        <div class="absolute select-none pointer-events-none text-[8rem] md:text-[12rem] font-black uppercase tracking-widest text-gray-500/[0.05] dark:text-white/[0.03] leading-none select-none">
            DELICIOUS
        </div>
        <div class="relative z-10 flex flex-col items-center" data-aos="fade-up">
            <div class="flex items-center space-x-3 mb-2">
                <div class="h-[2px] w-8 bg-orange-600"></div>
                <span class="text-orange-600 dark:text-orange-500 font-bold uppercase tracking-[0.4em] text-xs md:text-sm">Authentic Taste</span>
                <div class="h-[2px] w-8 bg-orange-600"></div>
            </div>
            <h2 class="text-5xl md:text-7xl font-black text-gray-900 dark:text-white uppercase tracking-tighter">
                OUR <span class="text-orange-600">MENU</span>
            </h2>
        </div>
    </div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 px-6 max-w-7xl mx-auto py-10">
    <% Object.values(products).slice(0, 3).forEach(function(item){ %>
    <div class="group relative flex flex-col items-center bg-white dark:bg-gray-800/40 p-8 rounded-[2.5rem] border border-gray-100 dark:border-gray-700/50 transition-all duration-500 hover:shadow-[0_20px_50px_rgba(234,88,12,0.15)] dark:hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)] hover:-translate-y-3 backdrop-blur-md" data-aos="fade-up">
            
            <div class="absolute top-20 w-32 h-32 bg-orange-500/20 blur-[50px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <div class="relative z-10 mb-8">
                <div class="h-48 w-48 md:h-56 md:w-56 overflow-hidden rounded-full border-4 border-white dark:border-gray-700 p-2 shadow-xl group-hover:border-orange-500 transition-all duration-500">
                    <img src="/images/product/<%= item.image %>" alt="<%= item.name %>"
                         class="h-full w-full rounded-full object-cover transition-transform duration-700 group-hover:scale-110 group-hover:rotate-3">
                </div>
            </div>

            <div class="relative z-10 text-center w-full">
                <h3 class="text-2xl font-bold text-gray-900 dark:text-white group-hover:text-orange-600 transition-colors duration-300">
                    <%= item.name %>
                </h3>

                <div class="mt-3 flex items-center justify-center space-x-1">
                    <span class="text-sm font-bold text-orange-600">฿</span>
                    <span class="text-3xl font-black text-gray-900 dark:text-white leading-none">
                        <%= item.price %>
                    </span>
                </div>

                <div class="mx-auto my-5 h-1 w-10 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden transition-all duration-500 group-hover:w-20">
                    <div class="h-full w-0 bg-orange-600 group-hover:w-full transition-all duration-700 delay-100"></div>
                </div>

                <% if (locals.user) { %>
                    <button onclick="addToCart('<%= item._id %>')" class="relative w-full py-3 px-6 bg-gray-900 dark:bg-white text-white dark:text-black rounded-2xl font-black text-sm tracking-widest uppercase overflow-hidden transition-all duration-300 active:scale-95 group-hover:bg-orange-600 group-hover:text-white shadow-lg">
                        <span class="relative z-10">Add to Order</span>
                        <div class="absolute inset-0 w-0 bg-white/20 transition-all duration-300 group-hover:w-full"></div>
                    </button>
                <% } else { %>
                    <a href="/signin" class="relative block w-full py-3 px-6 bg-gray-900 dark:bg-white text-white dark:text-black rounded-2xl font-black text-sm tracking-widest uppercase overflow-hidden transition-all duration-300 active:scale-95 group-hover:bg-orange-600 group-hover:text-white shadow-lg text-center">
                        <span class="relative z-10">Add to Order</span>
                        <div class="absolute inset-0 w-0 bg-white/20 transition-all duration-300 group-hover:w-full"></div>
                    </a>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>

<% if (promotions && promotions.length > 0) { %>
    <section class="py-20 px-6 bg-slate-50 dark:bg-[#0f0f0f]">
        <div class="flex flex-col gap-10">
            <% promotions.forEach(promo => { %>
                <div class="max-w-6xl mx-auto w-full">
                    <div class="relative overflow-hidden rounded-3xl bg-white shadow-xl dark:bg-gray-900 border border-gray-100 dark:border-gray-800">
                        <div class="grid grid-cols-1 md:grid-cols-2">
                            <div class="p-10 md:p-16 flex flex-col justify-center">
                                <div class="flex flex-wrap items-center gap-3 mb-4">
                                    <span class="inline-block px-3 py-1 rounded-full bg-orange-100 dark:bg-orange-900/30 text-orange-600 dark:text-orange-400 text-xs font-bold uppercase tracking-widest w-fit">
                                        Limited Time Offer
                                    </span>
                                    <% if (promo.startDate && promo.endDate) { %>
                                        <span class="text-sm font-semibold text-gray-500 dark:text-gray-400 flex items-center gap-1.5">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                                            <%= new Date(promo.startDate).toLocaleDateString('en-GB') %> - <%= new Date(promo.endDate).toLocaleDateString('en-GB') %>
                                        </span>
                                    <% } %>
                                </div>
                                <h2 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white mb-6 uppercase">
                                    <%= promo.title %>
                                </h2>
                                <p class="text-gray-600 dark:text-gray-400 mb-8 leading-relaxed">
                                    <%= promo.description %>
                                </p>
                                <button class="w-fit px-8 py-3 bg-gray-900 dark:bg-orange-600 text-white font-bold rounded-xl hover:scale-105 transition-transform">
                                    Check Details
                                </button>
                            </div>
                            <div class="relative h-64 md:h-auto bg-gray-200 dark:bg-gray-800">
                                <img src="/images/promotions/<%= promo.imageFilename %>" class="absolute inset-0 w-full h-full object-cover" alt="<%= promo.title %>">
                            </div>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>
<% } %>

        <section class="py-24 bg-orange-50/50 dark:bg-[#0c0c0c]">
            <div class="max-w-6xl mx-auto px-6">

                <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
                    <div>
                        <span class="text-orange-600 font-bold tracking-widest uppercase text-sm">Highly
                            Recommended</span>
                        <h2 class="text-4xl font-black text-gray-900 dark:text-white mt-2">CHEF'S <span
                                class="text-orange-600">SELECTION</span></h2>
                    </div>
                    <p class="text-gray-500 dark:text-gray-400 max-w-md">
                        เมนูพิเศษที่เชฟคัดสรรวัตถุดิบที่ดีที่สุดในแต่ละวัน เพื่อส่งมอบรสชาติระดับพรีเมียมให้คุณ
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <% Object.values(products).slice(0, 2).forEach(function(item){ %>
                        <div
                            class="group relative flex flex-col sm:flex-row bg-white dark:bg-gray-900 rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-gray-800">

                            <div class="w-full sm:w-1/2 h-64 sm:h-auto overflow-hidden">
                                <img src="/images/product/<%= item.image %>"
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                    alt="<%= item.name %>">
                            </div>

                            <div class="p-8 flex flex-col justify-between sm:w-1/2">
                                <div>
                                    <div class="flex justify-between items-start mb-2">
                                        <h3 class="text-xl font-bold text-gray-900 dark:text-white leading-tight">
                                            <%= item.name %>
                                        </h3>
                                        <span
                                            class="bg-orange-600 text-white text-[10px] px-2 py-1 rounded font-bold uppercase tracking-tighter">New</span>
                                    </div>
                                    <p class="text-gray-500 dark:text-gray-400 text-sm line-clamp-2 mt-2">
                                        รสสัมผัสที่เป็นเอกลักษณ์เฉพาะตัว ผสมผสานเครื่องเทศนำเข้าจากญี่ปุ่น
                                    </p>
                                </div>

                                <div class="mt-6 flex items-center justify-between">
                                    <div>
                                        <span class="text-xs text-gray-400 block uppercase font-bold">Price</span>
                                        <span class="text-2xl font-black text-orange-600 dark:text-orange-500">฿<%=
                                                item.price %></span>
                                    </div>

                                    <button
                                        class="h-12 w-12 rounded-2xl bg-gray-900 dark:bg-white text-white dark:text-black flex items-center justify-center transition-all hover:bg-orange-600 dark:hover:bg-orange-500 dark:hover:text-white group-hover:rotate-12 shadow-lg">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
                                            viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 4v16m8-8H4" />
                                        </svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </div>
        </section>
        <section class="py-24 px-6 bg-white dark:bg-black">
            <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
                <div class="relative w-full md:w-1/2">
                    <div class="absolute -top-4 -left-4 w-full h-full border-2 border-orange-600/20 rounded-2xl -z-10">
                    </div>
                    <div class="overflow-hidden rounded-2xl shadow-2xl">
                        <img src="/images/background/5amramen.jpg" alt="Secret Process"
                            class="w-full h-[400px] object-cover hover:scale-105 transition-transform duration-1000">
                    </div>
                    <div
                        class="absolute -bottom-6 -right-6 w-24 h-24 bg-orange-600 rounded-full flex items-center justify-center text-white text-[10px] font-bold text-center p-2 animate-spin-slow shadow-lg">
                        18 HOURS SLOW COOKED
                    </div>
                </div>

                <div class="w-full md:w-1/2 space-y-6">
                    <h2 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white leading-tight">
                        THE SECRET BEHIND <br><span class="text-orange-600">EVERY BOWL</span>
                    </h2>
                    <p class="text-gray-600 dark:text-gray-400 leading-relaxed italic">
                        "เราเชื่อว่าราเมงที่ดีเริ่มจากความอดทน น้ำซุปทุกหยดของเราผ่านการเคี่ยวจนเข้มข้น
                        เพื่อส่งมอบรสชาติที่เป็นเอกลักษณ์ที่สุด"
                    </p>
                    <div class="grid grid-cols-2 gap-6 pt-4">
                        <div class="border-l-2 border-orange-600 pl-4">
                            <h4 class="font-bold text-gray-900 dark:text-white text-lg">Hokkaido Flour</h4>
                            <p class="text-sm text-gray-500">เส้นสดนวดใหม่ทุกวัน</p>
                        </div>
                        <div class="border-l-2 border-orange-600 pl-4">
                        <h4 class="font-bold text-gray-900 dark:text-white text-lg">Premium Pork</h4>
                        <p class="text-sm text-gray-500">หมูชาชูนุ่มละลายในปาก</p>
                    </div>
                </div>
            </div>
        </div>
 </section>


 <%- include('footer.ejs') %>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <script>
        lucide.createIcons();
        AOS.init({
                duration: 1000,
                once: false,
                mirror: true,
                anchorPlacement: 'top-bottom',
        });

        function toggleTheme() {
            const html = document.documentElement;
            if (html.classList.contains('dark')) {
                html.classList.remove('dark');
                localStorage.setItem('theme', 'light');
            } else {
                html.classList.add('dark');
                localStorage.setItem('theme', 'dark');
            }
            lucide.createIcons();
            updateChartTheme();
            } 

        function showToast(message, isSuccess ) {
            let container = document.getElementById('toast-container');

            if (!container) {
                container = document.createElement('div');
                container.id = 'toast-container';
                container.className = 'fixed bottom-5 right-5 z-50 flex flex-col gap-2';
                document.body.appendChild(container);
            }

            const toast = document.createElement('div');

            const bgColor = isSuccess ? 'bg-green-600 dark:bg-green-500' : 'bg-red-600 dark:bg-red-500';
            const iconName = isSuccess ? 'check-circle' : 'alert-circle';

            toast.className = `flex items-center gap-3 px-5 py-3.5 rounded-2xl shadow-xl text-white transform transition-all duration-300 translate-y-10 opacity-0 pointer-events-auto ${bgColor}`;
            toast.innerHTML = `
                <i data-lucide="${iconName}" class="w-5 h-5 flex-shrink-0"></i>
                <span class="text-sm font-medium tracking-wide">${message}</span>
            `;

            container.appendChild(toast);

            if (typeof lucide !== 'undefined') {
                lucide.createIcons();
            }

            setTimeout(() => {
                toast.classList.remove('translate-y-10', 'opacity-0');
            }, 10);

            setTimeout(() => {
                toast.classList.add('translate-y-10', 'opacity-0');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        async function addToCart(productId) {
        try {
            let res;
            if (typeof axios !== 'undefined') {
            res = await axios.post('/cart/add', { productId: productId, quantity: 1 });
        } else {
            const response = await fetch('/cart/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ productId: productId, quantity: 1 })
            });
            res = { data: await response.json() };
        }
        
        if (res.data.success) {
            showToast(res.data.message, true);

            const badge = document.getElementById('cart-count-badge');
            if (badge && res.data.newCount !== undefined) {
                badge.innerText = res.data.newCount; 
                badge.classList.remove('hidden');  
            } else {
                setTimeout(() => window.location.reload(), 1000);
            }
        } else {
            showCustomToast(res.data.message, false);

            if (res.data.message === "Please sign in to order!") {
                setTimeout(() => window.location.href = '/signin', 1500);
            }
        }
    } catch (error) {
        console.error(error);
        const errorMessage = error.response?.data?.message || error.message;
        showCustomToast('Error: ' + errorMessage, false);
    }
}
    </script>
        
</body>

</html>