<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../head.ejs') %>
</head>
<body class="bg-kaizen-bg dark:bg-kaizen-darker text-zinc-800 dark:text-zinc-100 transition-colors duration-300 min-h-screen font-sans">
    <div class="flex flex-col min-h-screen">
        <main class="p-4 md:p-10 flex-grow">
            <div class="max-w-7xl mx-auto">
                 <div class="mb-6">
                        <button onclick="history.back()" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-amber-600 dark:text-gray-400 dark:hover:text-amber-500 transition-colors font-medium group">
                            <i data-lucide="arrow-left" class="w-4 h-4 transition-transform group-hover:-translate-x-1"></i>
                            Back
                        </button>
                    </div>
                <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
                    <div>
                        <h1 class="text-4xl font-black tracking-wide text-zinc-900 dark:text-zinc-100 uppercase">
                            Kaizen <span class="text-kaizen-orange">Members</span>
                        </h1>
                        <p class="text-zinc-500 dark:text-zinc-400 font-medium italic mt-1">"Rewarding our loyal ramen enthusiasts."</p>
                    </div>
                </div>

                <div class="bg-white dark:bg-kaizen-dark border border-kaizen-tan dark:border-zinc-800 rounded-2xl shadow-sm overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-[#f5ece0] dark:bg-zinc-900 border-b border-kaizen-tan dark:border-zinc-800 text-zinc-700 dark:text-zinc-300 text-xs uppercase font-bold tracking-widest">
                                    <th class="px-6 py-4">Member Info</th>
                                    <th class="px-6 py-4">Contact</th>
                                    <th class="px-6 py-4">Tier & Points</th>
                                    <th class="px-6 py-4">Join Date</th>
                                    <th class="px-6 py-4 text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-kaizen-tan/50 dark:divide-zinc-800">
                                <% if(typeof members !== 'undefined' && members.length > 0) { %>
                                    <% members.forEach(member => { %>
                                    <tr class="hover:bg-[#faf8f5] dark:hover:bg-zinc-800/50 transition-colors group">
                                        <td class="px-6 py-5">
                                            <div class="font-bold text-zinc-900 dark:text-zinc-100 text-base"><%= member.name %></div>
                                            <div class="text-xs text-zinc-500 mt-1">ID: <%= member._id.toString().substring(0,8) %></div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <div class="text-sm text-zinc-700 dark:text-zinc-300"><%= member.email %></div>
                                            <div class="text-xs text-kaizen-orange mt-1"><%= member.phone %></div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider
                                                <%= member.tier === 'Gold' ? 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400' : 
                                                    member.tier === 'Silver' ? 'bg-zinc-200 text-zinc-700 dark:bg-zinc-700 dark:text-zinc-300' : 
                                                    'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-500' %>">
                                                <%= member.tier || 'Bronze' %>
                                            </span>
                                            <div class="text-sm font-bold mt-2 text-zinc-900 dark:text-white"><%= member.points || 0 %> pts</div>
                                        </td>
                                        <td class="px-6 py-5">
                                            <div class="text-sm text-zinc-500"><%= new Date(member.createdAt).toLocaleDateString() %></div>
                                        </td>
                                        <td class="px-6 py-5 text-right">
                                            <div class="inline-flex items-center space-x-3">
                                                <form id="delete-form-<%= member._id %>" action="/member/delete/<%= member._id %>" method="POST" class="inline">
                                                    <button type="button" onclick="confirmDelete('<%= member._id %>', '<%= member.name %>')" class="text-zinc-400 hover:text-kaizen-red transition-colors">
                                                        <i data-lucide="trash-2" class="w-5 h-5"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="py-16 text-center">
                                            <div class="flex flex-col items-center justify-center">
                                                <i data-lucide="users" class="w-12 h-12 text-kaizen-tan dark:text-zinc-700 mb-4"></i>
                                                <p class="text-zinc-500 text-base font-medium">No members registered yet.</p>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        lucide.createIcons();
        function toggleTheme() {
        const html = document.documentElement;
        if (html.classList.contains('dark')) {
          html.classList.remove('dark');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        lucide.createIcons();
        updateChartTheme();
      }

        function confirmDelete(id, name) {
            const isDark = document.documentElement.classList.contains('dark');
            Swal.fire({
                title: 'Remove Member?',
                html: `Are you sure you want to remove <b>${name}</b> from the system?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#E60000',
                cancelButtonColor: isDark ? '#3f3f46' : '#a1a1aa',
                background: isDark ? '#18181b' : '#ffffff',
                color: isDark ? '#f4f4f5' : '#18181b',
                confirmButtonText: 'Yes, remove them'
            }).then((result) => {
                if (result.isConfirmed) document.getElementById(`delete-form-${id}`).submit();
            })
        }
    </script>
</body>
</html>